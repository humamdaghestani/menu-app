<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>POS — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f0f1a; color: #e0e0e0; min-height: 100vh; }

    .topbar { background: #1a1a2e; height: 56px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; border-bottom: 1px solid rgba(255,255,255,.07); position: sticky; top: 0; z-index: 50; }
    .topbar-brand { font-weight: 700; color: #fff; font-size: 1rem; }
    .btn { padding: 7px 16px; border: none; border-radius: 8px; cursor: pointer; font-size: .82rem; font-weight: 600; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
    .btn-ghost { background: rgba(255,255,255,.08); color: #ccc; }
    .btn-ghost:hover { background: rgba(255,255,255,.14); color: #fff; }

    .main { padding: 28px 24px; max-width: 800px; margin: 0 auto; }

    /* Session Status Card */
    .session-card { border-radius: 16px; padding: 24px 28px; margin-bottom: 32px; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
    .session-card.open  { background: rgba(0,184,148,.08); border: 1.5px solid rgba(0,184,148,.3); }
    .session-card.closed { background: rgba(241,196,15,.06); border: 1.5px solid rgba(241,196,15,.25); }
    .session-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .session-dot.open   { background: #00b894; box-shadow: 0 0 8px #00b894; }
    .session-dot.closed { background: #888; }
    .session-info { flex: 1; }
    .session-info h2 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .session-info p  { font-size: .8rem; color: #666; }
    .session-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn-open-session { background: #f1c40f; color: #111; font-weight: 700; }
    .btn-open-session:hover { opacity: .88; }
    .btn-continue { background: #00b894; color: #fff; }
    .btn-continue:hover { opacity: .88; }
    .btn-close-session { background: rgba(231,76,60,.15); color: #e74c3c; border: 1px solid rgba(231,76,60,.3); }
    .btn-close-session:hover { background: rgba(231,76,60,.25); }

    /* Stats in session card */
    .session-stats { display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap; }
    .session-stat { }
    .session-stat-label { font-size: .65rem; color: #555; text-transform: uppercase; font-weight: 700; }
    .session-stat-val   { font-size: .95rem; font-weight: 700; color: #fff; }
    .session-stat-val.green { color: #00b894; }

    /* Passkey generator */
    .passkey-section { background: #1a1a2e; border: 1.5px solid rgba(124,92,191,.25); border-radius: 16px; padding: 22px 24px; margin-bottom: 28px; }
    .passkey-section h2 { font-size: .88rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .passkey-section p  { font-size: .78rem; color: #555; margin-bottom: 16px; }
    .passkey-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .btn-gen-void     { background: rgba(231,76,60,.15); color: #e74c3c; border: 1px solid rgba(231,76,60,.3); }
    .btn-gen-void:hover { background: rgba(231,76,60,.25); }
    .btn-gen-discount { background: rgba(0,184,148,.12); color: #00b894; border: 1px solid rgba(0,184,148,.28); }
    .btn-gen-discount:hover { background: rgba(0,184,148,.22); }
    .passkey-display { display: none; background: #0f0f1a; border-radius: 12px; padding: 20px 24px; text-align: center; border: 1px solid rgba(255,255,255,.06); }
    .passkey-type-label { font-size: .7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
    .passkey-code { font-size: 3rem; font-weight: 900; letter-spacing: 10px; color: #fff; font-family: monospace; margin-bottom: 8px; }
    .passkey-countdown { font-size: .78rem; color: #555; }
    .passkey-countdown.urgent { color: #e74c3c; }

    /* Nav grid */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
    .nav-card { background: #1a1a2e; border: 1.5px solid rgba(255,255,255,.07); border-radius: 16px; padding: 24px 20px; text-decoration: none; color: inherit; transition: all .2s; cursor: pointer; display: block; }
    .nav-card:hover { border-color: #7c5cbf; transform: translateY(-2px); background: #1e1e38; }
    .nav-card.disabled { opacity: .4; pointer-events: none; }
    .nav-icon { font-size: 2rem; margin-bottom: 12px; }
    .nav-title { font-size: .95rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .nav-desc  { font-size: .75rem; color: #555; }

    @media (max-width: 500px) { .session-card { flex-direction: column; align-items: flex-start; } .main { padding: 16px; } }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">🖥️ POS — <%= tenant.name %></div>
  <a href="/admin" class="btn btn-ghost">← Admin</a>
</div>

<div class="main">

  <!-- Session Status -->
  <% if (session) { %>
  <div class="session-card open">
    <div class="session-dot open"></div>
    <div class="session-info">
      <h2>Session #<%= session.id %> is active</h2>
      <p>Opened at <%= new Date(session.opened_at).toLocaleString() %></p>
      <div class="session-stats">
        <div class="session-stat">
          <div class="session-stat-label">Opening Cash</div>
          <div class="session-stat-val"><%= tenant.currency || '$' %><%= parseFloat(session.opening_cash).toFixed(2) %></div>
        </div>
        <div class="session-stat">
          <div class="session-stat-label">Orders</div>
          <div class="session-stat-val"><%= stats.cnt %></div>
        </div>
        <div class="session-stat">
          <div class="session-stat-label">Sales</div>
          <div class="session-stat-val green"><%= tenant.currency || '$' %><%= parseFloat(stats.sales).toFixed(2) %></div>
        </div>
      </div>
    </div>
    <div class="session-actions">
      <a href="/pos/tables" class="btn btn-continue">Go to Tables →</a>
      <a href="/pos/session/close" class="btn btn-close-session">🔒 Close</a>
    </div>
  </div>
  <% } else { %>
  <div class="session-card closed">
    <div class="session-dot closed"></div>
    <div class="session-info">
      <h2>No active session</h2>
      <p>Open a session to start taking orders</p>
    </div>
    <div class="session-actions">
      <a href="/pos/session/open" class="btn btn-open-session">Open Session →</a>
    </div>
  </div>
  <% } %>

  <!-- Passkey Generator (admin only) -->
  <% if (_isAdmin) { %>
  <div class="passkey-section">
    <h2>🔑 Manager Passkeys</h2>
    <p>Generate a one-time code for a cashier to void an order or apply a discount. Code expires in 15 minutes.</p>
    <div class="passkey-btns">
      <button class="btn btn-gen-void"     onclick="generatePasskey('void')">Generate Void Code</button>
      <button class="btn btn-gen-discount" onclick="generatePasskey('discount')">Generate Discount Code</button>
    </div>
    <div class="passkey-display" id="passkeyDisplay">
      <div class="passkey-type-label" id="passkeyTypeLabel"></div>
      <div class="passkey-code" id="passkeyCode"></div>
      <div class="passkey-countdown" id="passkeyCountdown"></div>
    </div>
  </div>
  <% } %>

  <!-- Navigation Grid -->
  <div class="grid">
    <a href="<%= session ? '/pos/tables' : '/pos/session/open' %>" class="nav-card">
      <div class="nav-icon">🗺️</div>
      <div class="nav-title">Table Map</div>
      <div class="nav-desc"><%= session ? 'View and manage tables' : 'Open a session first' %></div>
    </a>

    <a href="<%= session ? '/pos/orders' : '#' %>" class="nav-card <%= session ? '' : 'disabled' %>">
      <div class="nav-icon">📋</div>
      <div class="nav-title">Orders</div>
      <div class="nav-desc">Current session orders</div>
    </a>

    <a href="/pos/sessions" class="nav-card">
      <div class="nav-icon">📅</div>
      <div class="nav-title">Sessions</div>
      <div class="nav-desc">History of all shifts</div>
    </a>

    <a href="/pos/settings" class="nav-card">
      <div class="nav-icon">⚙️</div>
      <div class="nav-title">Settings</div>
      <div class="nav-desc">Tables & permissions</div>
    </a>

    <a href="/pos/kitchen" class="nav-card">
      <div class="nav-icon">🍳</div>
      <div class="nav-title">Kitchen Display</div>
      <div class="nav-desc">Live order queue</div>
    </a>
  </div>

</div>

<% if (_isAdmin) { %>
<script>
  let countdownInterval = null;

  async function generatePasskey(actionType) {
    try {
      const res = await fetch('/pos/passkey/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action_type: actionType })
      });
      const data = await res.json();
      if (!data.ok) { alert('Failed to generate passkey'); return; }

      const display = document.getElementById('passkeyDisplay');
      const typeLabel = document.getElementById('passkeyTypeLabel');
      const codeEl = document.getElementById('passkeyCode');
      const countdown = document.getElementById('passkeyCountdown');

      typeLabel.textContent = actionType === 'void' ? '🗑️ VOID PASSKEY' : '💸 DISCOUNT PASSKEY';
      typeLabel.style.color = actionType === 'void' ? '#e74c3c' : '#00b894';
      codeEl.textContent = data.code;
      display.style.display = 'block';

      if (countdownInterval) clearInterval(countdownInterval);
      let secsLeft = data.expires_in;

      function tick() {
        if (secsLeft <= 0) {
          clearInterval(countdownInterval);
          display.style.display = 'none';
          return;
        }
        const m = Math.floor(secsLeft / 60).toString().padStart(2, '0');
        const s = (secsLeft % 60).toString().padStart(2, '0');
        countdown.textContent = `Expires in ${m}:${s}`;
        countdown.className = 'passkey-countdown' + (secsLeft <= 60 ? ' urgent' : '');
        secsLeft--;
      }
      tick();
      countdownInterval = setInterval(tick, 1000);
    } catch (e) {
      alert('Network error');
    }
  }
</script>
<% } %>

</body>
</html>

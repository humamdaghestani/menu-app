<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order — <%= order.table_name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f0f1a; color: #e0e0e0; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

    /* ── Topbar ── */
    .topbar { background: #1a1a2e; height: 52px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; border-bottom: 1px solid rgba(255,255,255,.07); flex-shrink: 0; gap: 12px; }
    .topbar-left { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .table-chip { background: rgba(124,92,191,.2); color: #a78bdf; font-weight: 700; font-size: .82rem; padding: 4px 12px; border-radius: 20px; white-space: nowrap; }
    .order-num { font-size: .75rem; color: #444; }
    .topbar-right { display: flex; gap: 6px; flex-shrink: 0; }
    .btn { padding: 6px 12px; border: none; border-radius: 7px; cursor: pointer; font-size: .78rem; font-weight: 600; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; }
    .btn-ghost { background: rgba(255,255,255,.07); color: #999; }
    .btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; }
    .btn-danger { background: rgba(255,71,87,.12); color: #ff6b7a; }
    .btn-pay { background: #00b894; color: #fff; font-size: .85rem; padding: 7px 18px; }
    .btn-pay:hover { opacity: .88; }
    .btn-pay:disabled { opacity: .35; cursor: not-allowed; }

    /* ── Main layout ── */
    .layout { display: flex; flex: 1; overflow: hidden; }

    /* ── Menu Panel ── */
    .menu-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

    .search-bar { padding: 10px 12px; background: #13132a; border-bottom: 1px solid rgba(255,255,255,.05); flex-shrink: 0; }
    .search-input { width: 100%; padding: 8px 14px 8px 36px; background: #0f0f1a; border: 1.5px solid #2a2a3e; border-radius: 8px; color: #fff; font-size: .85rem; outline: none; font-family: inherit; }
    .search-input:focus { border-color: #7c5cbf; }
    .search-wrap { position: relative; }
    .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #444; font-size: .9rem; pointer-events: none; }

    .cat-bar { display: flex; gap: 6px; padding: 10px 12px; background: #13132a; border-bottom: 1px solid rgba(255,255,255,.05); overflow-x: auto; scrollbar-width: none; flex-shrink: 0; }
    .cat-bar::-webkit-scrollbar { display: none; }
    .cat-btn { padding: 5px 14px; border-radius: 20px; border: 1.5px solid #2a2a3e; background: none; color: #666; font-size: .75rem; font-weight: 600; cursor: pointer; white-space: nowrap; font-family: inherit; transition: all .15s; }
    .cat-btn.active { background: #7c5cbf; border-color: #7c5cbf; color: #fff; }
    .cat-btn:hover:not(.active) { border-color: #555; color: #ccc; }

    .items-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 8px; padding: 10px 12px; overflow-y: auto; flex: 1; align-content: start; }
    .item-card { background: #1a1a2e; border-radius: 10px; border: 1.5px solid #2a2a3e; cursor: pointer; transition: all .15s; overflow: hidden; }
    .item-card:hover { border-color: #7c5cbf; transform: translateY(-1px); }
    .item-card:active { transform: scale(.97); }
    .item-card-img { width: 100%; height: 72px; object-fit: cover; display: block; background: #2a2a3e; }
    .item-card-img-placeholder { width: 100%; height: 72px; background: linear-gradient(135deg,#1e1e3a,#2a2a4e); display: flex; align-items: center; justify-content: center; font-size: 1.6rem; }
    .item-card-body { padding: 8px 10px; }
    .item-card-name { font-size: .78rem; font-weight: 600; color: #ddd; line-height: 1.3; margin-bottom: 4px; }
    .item-card-price { font-size: .8rem; color: #7c5cbf; font-weight: 700; }
    .item-card.hidden { display: none; }

    /* ── Order Panel ── */
    .order-panel { width: 320px; flex-shrink: 0; display: flex; flex-direction: column; background: #13132a; border-left: 1px solid rgba(255,255,255,.06); }

    .order-actions { display: flex; gap: 5px; padding: 10px 10px 0; flex-wrap: wrap; }
    .action-btn { flex: 1; min-width: 60px; padding: 7px 6px; border-radius: 8px; border: 1.5px solid #2a2a3e; background: #0f0f1a; color: #888; font-size: .72rem; font-weight: 600; cursor: pointer; font-family: inherit; text-align: center; transition: all .15s; }
    .action-btn:hover { border-color: #7c5cbf; color: #c4b5fd; background: rgba(124,92,191,.08); }
    .action-btn.active { border-color: #7c5cbf; color: #c4b5fd; background: rgba(124,92,191,.12); }

    .order-list { flex: 1; overflow-y: auto; padding: 8px; }
    .order-empty { text-align: center; padding: 32px 12px; color: #333; font-size: .82rem; line-height: 1.6; }

    .order-item { display: flex; align-items: flex-start; gap: 6px; padding: 8px 6px; border-radius: 8px; border-bottom: 1px solid rgba(255,255,255,.04); }
    .order-item:last-child { border-bottom: none; }
    .oi-info { flex: 1; min-width: 0; }
    .oi-name { font-size: .8rem; color: #ddd; font-weight: 600; line-height: 1.3; }
    .oi-note { font-size: .7rem; color: #555; margin-top: 2px; display: flex; align-items: center; gap: 4px; }
    .oi-note-edit { background: none; border: none; color: #555; cursor: pointer; font-size: .68rem; padding: 0; font-family: inherit; text-decoration: underline; }
    .oi-note-edit:hover { color: #888; }
    .qty-ctrl { display: flex; align-items: center; gap: 3px; }
    .qty-btn { width: 22px; height: 22px; border-radius: 5px; border: none; background: #2a2a3e; color: #ccc; cursor: pointer; font-size: .85rem; font-weight: 700; display: flex; align-items: center; justify-content: center; padding: 0; }
    .qty-btn:hover { background: #7c5cbf; color: #fff; }
    .qty-num { font-size: .8rem; color: #fff; font-weight: 700; width: 18px; text-align: center; }
    .oi-price { font-size: .8rem; color: #7c5cbf; font-weight: 700; white-space: nowrap; min-width: 48px; text-align: right; }

    .order-footer { padding: 10px 12px; border-top: 1px solid rgba(255,255,255,.06); }
    .totals { margin-bottom: 12px; }
    .total-row { display: flex; justify-content: space-between; font-size: .8rem; color: #666; padding: 2px 0; }
    .total-row.discount { color: #00b894; }
    .total-row.grand { font-size: 1rem; font-weight: 700; color: #fff; padding-top: 8px; border-top: 1px solid #2a2a3e; margin-top: 6px; }

    /* ── Modals ── */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: #1a1a2e; border-radius: 14px; border: 1px solid rgba(255,255,255,.1); padding: 24px; width: 100%; max-width: 360px; }
    .modal-box h3 { font-size: .95rem; font-weight: 700; color: #fff; margin-bottom: 16px; }
    .modal-input { width: 100%; padding: 10px 12px; background: #0f0f1a; border: 1.5px solid #2a2a3e; border-radius: 8px; color: #fff; font-size: .9rem; outline: none; font-family: inherit; margin-bottom: 12px; }
    .modal-input:focus { border-color: #7c5cbf; }
    .modal-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
    .btn-modal-cancel { background: rgba(255,255,255,.07); color: #888; }
    .btn-modal-ok { background: #7c5cbf; color: #fff; }
    .type-toggle { display: flex; gap: 6px; margin-bottom: 12px; }
    .type-btn { flex: 1; padding: 8px; border: 1.5px solid #2a2a3e; border-radius: 8px; background: #0f0f1a; color: #888; font-size: .8rem; font-weight: 600; cursor: pointer; font-family: inherit; text-align: center; }
    .type-btn.active { border-color: #7c5cbf; color: #c4b5fd; background: rgba(124,92,191,.12); }

    .split-result { background: #0f0f1a; border-radius: 8px; padding: 12px; text-align: center; margin-bottom: 12px; }
    .split-per { font-size: 1.3rem; font-weight: 700; color: #fff; }
    .split-sub { font-size: .75rem; color: #555; margin-top: 4px; }

    @media (max-width: 680px) {
      .order-panel { width: 100%; position: fixed; bottom: 0; left: 0; right: 0; max-height: 55vh; z-index: 10; border-top: 2px solid #7c5cbf; border-left: none; }
      .menu-panel { padding-bottom: 55vh; }
      body { overflow: auto; height: auto; }
      .layout { flex-direction: column; height: auto; overflow: visible; }
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <span class="table-chip">🪑 <%= order.table_name %></span>
    <span class="order-num">#<%= order.id %></span>
  </div>
  <div class="topbar-right">
    <button class="btn btn-ghost" onclick="window.print()" title="Print bill">🖨️</button>
    <button class="btn btn-danger" onclick="openVoid()">🗑️ Void</button>
    <a href="/pos/tables" class="btn btn-ghost">← Tables</a>
  </div>
</div>

<div class="layout">

  <!-- ── Menu Panel ── -->
  <div class="menu-panel">
    <div class="search-bar">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" class="search-input" id="searchInput" placeholder="Search items..." oninput="filterItems()" />
      </div>
    </div>
    <div class="cat-bar">
      <button class="cat-btn active" data-cat="all" onclick="filterCat('all',this)">All</button>
      <% categories.forEach(c => { %>
      <button class="cat-btn" data-cat="<%= c.id %>" onclick="filterCat('<%= c.id %>',this)"><%= c.name %></button>
      <% }) %>
    </div>
    <div class="items-grid" id="itemsGrid">
      <% menuItems.forEach(item => { %>
      <div class="item-card" data-cat="<%= item.category_id %>" data-name="<%= item.name.toLowerCase() %>" onclick="addItem('<%= item.id %>')">
        <% if (item.image_url) { %>
        <img class="item-card-img" src="<%= item.image_url %>" alt="<%= item.name %>" loading="lazy" />
        <% } else { %>
        <div class="item-card-img-placeholder">🍽️</div>
        <% } %>
        <div class="item-card-body">
          <div class="item-card-name"><%= item.name %></div>
          <div class="item-card-price"><%= tenant.currency || '$' %><%= item.price %></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- ── Order Panel ── -->
  <div class="order-panel">
    <div class="order-actions">
      <button class="action-btn" onclick="openDiscount()">🏷️ Discount</button>
      <button class="action-btn" onclick="openSplit()">✂️ Split</button>
      <button class="action-btn" onclick="openOrderNote()">📝 Note</button>
      <button class="action-btn" onclick="window.print()">🖨️ Print</button>
    </div>

    <div class="order-list" id="orderList">
      <% if (orderItems.length === 0) { %>
      <div class="order-empty">Tap items on the left<br />to add them here</div>
      <% } else { %>
      <% orderItems.forEach(oi => { %>
      <div class="order-item">
        <div class="oi-info">
          <div class="oi-name"><%= oi.name %></div>
          <div class="oi-note">
            <% if (oi.notes) { %><span>📝 <%= oi.notes %></span><% } %>
            <button class="oi-note-edit" onclick="openItemNote(<%= oi.id %>, `<%= (oi.notes||'').replace(/`/g,'\\`') %>`)">
              <%= oi.notes ? 'edit note' : '+ note' %>
            </button>
          </div>
        </div>
        <div class="qty-ctrl">
          <form method="POST" action="/pos/order/<%= order.id %>/item/<%= oi.id %>/qty" style="display:contents">
            <input type="hidden" name="delta" value="-1" />
            <button type="submit" class="qty-btn">−</button>
          </form>
          <span class="qty-num"><%= oi.quantity %></span>
          <form method="POST" action="/pos/order/<%= order.id %>/item/<%= oi.id %>/qty" style="display:contents">
            <input type="hidden" name="delta" value="1" />
            <button type="submit" class="qty-btn">+</button>
          </form>
        </div>
        <div class="oi-price"><%= tenant.currency || '$' %><%= (oi.price * oi.quantity).toFixed(2) %></div>
      </div>
      <% }) %>
      <% } %>
    </div>

    <div class="order-footer">
      <div class="totals">
        <div class="total-row"><span>Subtotal</span><span><%= tenant.currency || '$' %><%= subtotal.toFixed(2) %></span></div>
        <% if (discount > 0) { %>
        <div class="total-row discount">
          <span>Discount (<%= order.discount_type === 'percent' ? order.discount_value + '%' : tenant.currency + parseFloat(order.discount_value).toFixed(2) %>)</span>
          <span>−<%= tenant.currency || '$' %><%= discount.toFixed(2) %></span>
        </div>
        <% } %>
        <% if (order.note) { %><div class="total-row"><span style="color:#f39c12">📝 <%= order.note %></span></div><% } %>
        <div class="total-row grand"><span>Total</span><span><%= tenant.currency || '$' %><%= total.toFixed(2) %></span></div>
      </div>
      <% if (orderItems.length > 0) { %>
      <a href="/pos/order/<%= order.id %>/pay" class="btn btn-pay" style="width:100%;justify-content:center;font-size:.9rem;padding:11px">
        💳 Pay <%= tenant.currency || '$' %><%= total.toFixed(2) %>
      </a>
      <% } else { %>
      <button class="btn btn-pay" disabled style="width:100%;justify-content:center;font-size:.9rem;padding:11px">💳 Pay</button>
      <% } %>
    </div>
  </div>
</div>

<!-- ── Add item form ── -->
<form method="POST" id="addForm" style="display:none" action="/pos/order/<%= order.id %>/add-item">
  <input type="hidden" name="menu_item_id" id="addItemId" />
</form>

<!-- ── Void Passkey Modal ── -->
<div class="modal-overlay" id="voidModal">
  <div class="modal-box">
    <h3>🗑️ Cancel Order</h3>
    <p style="font-size:.8rem;color:#666;margin-bottom:14px">Ask your manager to generate a <strong>Void</strong> passkey, then enter it below.</p>
    <form method="POST" action="/pos/order/<%= order.id %>/void">
      <label style="font-size:.7rem;color:#555;font-weight:700;display:block;margin-bottom:5px;text-transform:uppercase">Manager Passkey</label>
      <input type="text" class="modal-input" name="passkey" maxlength="6" minlength="6"
        placeholder="6-digit code" inputmode="numeric" autocomplete="off"
        style="font-size:1.4rem;letter-spacing:6px;text-align:center;font-weight:700" />
      <div class="modal-footer">
        <button type="button" class="btn btn-modal-cancel" onclick="closeModal('voidModal')">Cancel</button>
        <button type="submit" class="btn" style="background:#e74c3c;color:#fff;padding:6px 16px">Cancel Order</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Discount Modal ── -->
<div class="modal-overlay" id="discountModal">
  <div class="modal-box">
    <h3>🏷️ Apply Discount</h3>
    <form method="POST" action="/pos/order/<%= order.id %>/discount" id="discountForm">
      <div class="type-toggle">
        <button type="button" class="type-btn active" id="btnPct" onclick="setDiscType('percent')">% Percent</button>
        <button type="button" class="type-btn" id="btnFixed" onclick="setDiscType('fixed')">$ Fixed</button>
        <button type="button" class="type-btn" id="btnNone" onclick="setDiscType('none')">✕ Remove</button>
      </div>
      <input type="hidden" name="discount_type" id="discTypeInput" value="<%= order.discount_type || 'percent' %>" />
      <input type="number" class="modal-input" name="discount_value" id="discValueInput"
        value="<%= order.discount_value || '' %>" min="0" step="0.01" placeholder="Enter amount..." />
      <div id="passkeyField">
        <label style="font-size:.7rem;color:#555;font-weight:700;display:block;margin-bottom:5px;text-transform:uppercase">Manager Passkey</label>
        <input type="text" class="modal-input" name="passkey" id="discPasskey" maxlength="6" minlength="6"
          placeholder="6-digit code" inputmode="numeric" autocomplete="off"
          style="font-size:1.3rem;letter-spacing:6px;text-align:center;font-weight:700" />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-modal-cancel" onclick="closeModal('discountModal')">Cancel</button>
        <button type="submit" class="btn btn-modal-ok">Apply</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Split Modal ── -->
<div class="modal-overlay" id="splitModal">
  <div class="modal-box">
    <h3>✂️ Split Bill</h3>
    <label style="font-size:.78rem;color:#666;margin-bottom:6px;display:block">Number of people</label>
    <input type="number" class="modal-input" id="splitCount" value="2" min="2" max="20" oninput="calcSplit()" />
    <div class="split-result">
      <div class="split-per" id="splitPer"><%= tenant.currency || '$' %><%= (total / 2).toFixed(2) %></div>
      <div class="split-sub">per person</div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-modal-cancel" onclick="closeModal('splitModal')">Close</button>
    </div>
  </div>
</div>

<!-- ── Order Note Modal ── -->
<div class="modal-overlay" id="noteModal">
  <div class="modal-box">
    <h3>📝 Order Note</h3>
    <form method="POST" action="/pos/order/<%= order.id %>/note">
      <textarea class="modal-input" name="note" rows="3" placeholder="e.g. allergy info, special requests..."
        style="resize:vertical"><%= order.note || '' %></textarea>
      <div class="modal-footer">
        <button type="button" class="btn btn-modal-cancel" onclick="closeModal('noteModal')">Cancel</button>
        <button type="submit" class="btn btn-modal-ok">Save</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Item Note Modal ── -->
<div class="modal-overlay" id="itemNoteModal">
  <div class="modal-box">
    <h3>📝 Item Note</h3>
    <form method="POST" id="itemNoteForm">
      <input type="hidden" name="delta" value="0" />
      <textarea class="modal-input" name="note" id="itemNoteText" rows="3" placeholder="e.g. no onions, well done..."></textarea>
      <div class="modal-footer">
        <button type="button" class="btn btn-modal-cancel" onclick="closeModal('itemNoteModal')">Cancel</button>
        <button type="submit" class="btn btn-modal-ok">Save</button>
      </div>
    </form>
  </div>
</div>

<% if (errorParam === 'passkey') { %>
<div id="passkeyError" style="position:fixed;top:60px;left:50%;transform:translateX(-50%);background:#e74c3c;color:#fff;padding:10px 22px;border-radius:8px;font-size:.85rem;font-weight:700;z-index:999;box-shadow:0 4px 16px rgba(0,0,0,.3)">
  ✗ Invalid or expired passkey — ask manager for a new code
</div>
<% } %>

<script>
  const CUR   = '<%= tenant.currency || "$" %>';
  const TOTAL = <%= total.toFixed(2) %>;
  <% if (errorParam === 'passkey') { %>
  setTimeout(() => { const e = document.getElementById('passkeyError'); if(e) e.remove(); }, 4000);
  <% if (modalParam === 'discount') { %>setTimeout(() => openDiscount(), 100);<% } %>
  <% if (modalParam === 'void') { %>setTimeout(() => openVoid(), 100);<% } %>
  <% } %>

  /* ── Category & search filter ── */
  let activeCat = 'all';
  function filterCat(cat, btn) {
    activeCat = cat;
    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter();
  }
  function filterItems() { applyFilter(); }
  function applyFilter() {
    const q = document.getElementById('searchInput').value.toLowerCase().trim();
    document.querySelectorAll('.item-card').forEach(card => {
      const matchCat  = activeCat === 'all' || card.dataset.cat == activeCat;
      const matchName = !q || card.dataset.name.includes(q);
      card.classList.toggle('hidden', !(matchCat && matchName));
    });
  }

  /* ── Add item ── */
  function addItem(id) {
    document.getElementById('addItemId').value = id;
    document.getElementById('addForm').submit();
  }

  /* ── Modals ── */
  function openModal(id) { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(m => {
    m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });
  });

  /* ── Void ── */
  function openVoid() { openModal('voidModal'); }

  /* ── Discount ── */
  function openDiscount() { openModal('discountModal'); }
  function setDiscType(t) {
    document.getElementById('discTypeInput').value = t;
    ['Pct','Fixed','None'].forEach(x => document.getElementById('btn'+x).classList.remove('active'));
    const map = { percent:'Pct', fixed:'Fixed', none:'None' };
    document.getElementById('btn' + map[t]).classList.add('active');
    const isRemove = t === 'none';
    document.getElementById('discValueInput').style.display = isRemove ? 'none' : '';
    document.getElementById('passkeyField').style.display = isRemove ? 'none' : '';
    if (isRemove) document.getElementById('discPasskey').removeAttribute('required');
    else document.getElementById('discPasskey').setAttribute('required', '');
  }

  /* ── Split ── */
  function openSplit() { openModal('splitModal'); calcSplit(); }
  function calcSplit() {
    const n = parseInt(document.getElementById('splitCount').value) || 2;
    document.getElementById('splitPer').textContent = CUR + (TOTAL / n).toFixed(2);
  }

  /* ── Order note ── */
  function openOrderNote() { openModal('noteModal'); }

  /* ── Item note ── */
  function openItemNote(itemId, currentNote) {
    document.getElementById('itemNoteForm').action = '/pos/order/<%= order.id %>/item/' + itemId + '/note';
    document.getElementById('itemNoteText').value = currentNote;
    openModal('itemNoteModal');
  }
</script>

<!-- ── Print styles ── -->
<style>
  @media print {
    .topbar, .menu-panel, .order-actions, .qty-ctrl, .btn-pay, .oi-note-edit { display: none !important; }
    body { background: #fff; color: #000; height: auto; overflow: visible; }
    .layout { display: block; }
    .order-panel { width: 100%; border: none; background: #fff; }
    .order-list { overflow: visible; }
    .order-item { border-bottom: 1px solid #eee; }
    .oi-name, .oi-price, .qty-num { color: #000; }
    .total-row { color: #000; }
    .total-row.grand { color: #000; border-top: 2px solid #000; }

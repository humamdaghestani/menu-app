<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🚗 Valet Desk — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0b0d14;
      --surface: #161923;
      --surface2: #1e2335;
      --accent: #25d366;
      --accent2: #1da851;
      --danger: #ef4444;
      --text: #f0f2f8;
      --muted: rgba(240,242,248,0.45);
      --border: rgba(255,255,255,0.08);
      --card-radius: 18px;
    }
    body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; min-height: 100vh; }

    /* ── Header ── */
    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-logo { font-size: 1.5rem; }
    .header-info { flex: 1; }
    .header-info h1 { font-size: 1rem; font-weight: 700; line-height: 1.2; }
    .header-info span { font-size: 0.75rem; color: var(--muted); }
    .pending-badge {
      background: var(--danger);
      color: #fff;
      font-size: 0.85rem;
      font-weight: 800;
      padding: 4px 12px;
      border-radius: 99px;
      min-width: 36px;
      text-align: center;
      transition: transform .2s;
    }
    .pending-badge.pulse { animation: badgePulse .6s ease; }
    @keyframes badgePulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.3)} }
    .refresh-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
      animation: blink 2s ease infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── Main ── */
    main { padding: 24px; max-width: 960px; margin: 0 auto; }

    /* ── Empty state ── */
    .empty {
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }
    .empty .empty-icon { font-size: 4rem; margin-bottom: 16px; }
    .empty h2 { font-size: 1.1rem; font-weight: 600; margin-bottom: 6px; color: var(--text); }
    .empty p { font-size: .85rem; }

    /* ── Request Cards ── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--card-radius);
      padding: 22px 20px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      animation: cardIn .3s ease;
      position: relative;
      overflow: hidden;
    }
    .card.new-highlight { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(37,211,102,.2); }
    @keyframes cardIn { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:none; } }
    .card-tag {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent), #1a9c52);
      border-radius: var(--card-radius) var(--card-radius) 0 0;
    }
    .card-ticket {
      font-size: 2rem;
      font-weight: 900;
      letter-spacing: -0.5px;
      color: #fff;
      margin-top: 4px;
    }
    .card-name {
      font-size: .9rem;
      color: var(--muted);
      min-height: 20px;
    }
    .card-time {
      font-size: .78rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .done-btn {
      margin-top: 14px;
      width: 100%;
      padding: 12px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: .95rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      transition: background .18s, transform .12s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .done-btn:hover { background: var(--accent2); }
    .done-btn:active { transform: scale(.97); }
    .done-btn:disabled { background: #333; color: #666; cursor: default; }

    /* ── Done section ── */
    .section-title {
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 32px 0 12px;
    }
    .done-list { display: flex; flex-direction: column; gap: 8px; }
    .done-row {
      display: flex;
      align-items: center;
      gap: 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 16px;
      opacity: .55;
    }
    .done-check { color: var(--accent); font-size: 1.1rem; }
    .done-ticket { font-weight: 700; font-size: .95rem; }
    .done-info { flex: 1; }
    .done-name { font-size: .8rem; color: var(--muted); }
    .done-time { font-size: .75rem; color: var(--muted); }

    @media (max-width: 480px) {
      main { padding: 16px; }
      .cards-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-logo">🚗</div>
  <div class="header-info">
    <h1><%= tenant.name %></h1>
    <span>Valet Desk</span>
  </div>
  <div class="pending-badge" id="pendingBadge">0</div>
  <div class="refresh-dot" id="refreshDot" title="Live"></div>
</header>

<main>
  <div id="root"></div>
</main>

<script>
  const TENANT_SLUG = '<%- tenant.subdomain %>';
  let seenIds = new Set();
  let pendingRequests = [];
  let doneRequests    = [];

  function timeAgo(dateStr) {
    const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 60)  return `${diff}s ago`;
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    return `${Math.floor(diff/3600)}h ago`;
  }

  function playBeep() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, ctx.currentTime);
      osc.frequency.setValueAtTime(660, ctx.currentTime + 0.15);
      gain.gain.setValueAtTime(0.35, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);
      osc.start(ctx.currentTime);
      osc.stop(ctx.currentTime + 0.5);
    } catch(e) {}
  }

  async function markDone(id) {
    const btn = document.getElementById('done-' + id);
    if (btn) { btn.disabled = true; btn.textContent = '...'; }
    try {
      await fetch('/api/valet-request/' + id + '/done', { method: 'POST' });
      // Move from pending to done locally
      const req = pendingRequests.find(r => r.id == id);
      if (req) {
        pendingRequests = pendingRequests.filter(r => r.id != id);
        doneRequests.unshift(req);
        if (doneRequests.length > 20) doneRequests = doneRequests.slice(0, 20);
      }
      render();
    } catch(e) {
      if (btn) { btn.disabled = false; btn.textContent = '✓ Done'; }
    }
  }

  function render() {
    const badge = document.getElementById('pendingBadge');
    badge.textContent = pendingRequests.length;

    const root = document.getElementById('root');
    let html = '';

    if (pendingRequests.length === 0) {
      html += `
        <div class="empty">
          <div class="empty-icon">🟢</div>
          <h2>All clear!</h2>
          <p>No pending valet requests right now.</p>
        </div>`;
    } else {
      html += '<div class="cards-grid">';
      for (const r of pendingRequests) {
        const isNew = document.getElementById('card-' + r.id) === null;
        html += `
          <div class="card ${isNew ? 'new-highlight' : ''}" id="card-${r.id}">
            <div class="card-tag"></div>
            <div class="card-ticket">#${r.ticket_no}</div>
            <div class="card-name">${r.customer_name || '<span style="opacity:.4">No name</span>'}</div>
            <div class="card-time">⏱ ${timeAgo(r.created_at)}</div>
            <button class="done-btn" id="done-${r.id}" onclick="markDone(${r.id})">✓ Car Delivered</button>
          </div>`;
      }
      html += '</div>';
    }

    if (doneRequests.length > 0) {
      html += '<div class="section-title">Completed</div><div class="done-list">';
      for (const r of doneRequests) {
        html += `
          <div class="done-row">
            <span class="done-check">✓</span>
            <div class="done-info">
              <div class="done-ticket">#${r.ticket_no}</div>
              <div class="done-name">${r.customer_name || ''}</div>
            </div>
            <div class="done-time">${timeAgo(r.created_at)}</div>
          </div>`;
      }
      html += '</div>';
    }

    root.innerHTML = html;
  }

  async function poll() {
    try {
      const res  = await fetch('/api/valet-requests?tenant=' + TENANT_SLUG);
      const data = await res.json();
      const fresh = data.requests || [];

      // Detect genuinely new IDs
      const newIds = fresh.filter(r => !seenIds.has(r.id));
      if (newIds.length > 0 && seenIds.size > 0) {
        playBeep();
        const badge = document.getElementById('pendingBadge');
        badge.classList.remove('pulse');
        void badge.offsetWidth;
        badge.classList.add('pulse');
      }
      fresh.forEach(r => seenIds.add(r.id));

      // Keep locally-done items out of pending list
      const doneIds = new Set(doneRequests.map(r => r.id));
      pendingRequests = fresh.filter(r => !doneIds.has(r.id));

      render();
    } catch(e) {
      // network hiccup — just keep the old state
    }
  }

  // Initial load then refresh every 5 seconds
  poll();
  setInterval(poll, 5000);

  // Keep time-ago labels fresh every 30s
  setInterval(() => { if (pendingRequests.length || doneRequests.length) render(); }, 30000);
</script>
</body>
</html>

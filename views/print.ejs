<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= tenant.name %> — Menu</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --accent: <%= tenant.theme_color || '#e94560' %>; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; color: #1a1a2e; font-size: 13px; }

    /* ── Screen toolbar ── */
    .toolbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 99;
      background: #1a1a2e; color: #fff; padding: 12px 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,.2);
    }
    .toolbar-left { display: flex; align-items: center; gap: 10px; font-size: .9rem; }
    .toolbar a { color: rgba(255,255,255,.7); text-decoration: none; font-size: .85rem; }
    .toolbar a:hover { color: #fff; }
    .print-btn {
      background: var(--accent); color: #fff; border: none; border-radius: 8px;
      padding: 9px 20px; font-size: .88rem; font-weight: 700; cursor: pointer;
      font-family: inherit; display: flex; align-items: center; gap: 7px;
    }
    .print-btn:hover { opacity: .88; }

    /* ── Content ── */
    .page { max-width: 900px; margin: 72px auto 60px; padding: 0 24px; }

    /* ── Header ── */
    .print-header {
      text-align: center; padding: 32px 0 24px;
      border-bottom: 2px solid #1a1a2e; margin-bottom: 36px;
    }
    .print-logo { width: 80px; height: 80px; border-radius: 14px; object-fit: cover; margin-bottom: 14px; display: block; margin-left: auto; margin-right: auto; }
    .print-name { font-size: 2rem; font-weight: 900; letter-spacing: -.02em; }
    .print-desc { color: #666; margin-top: 6px; font-size: .9rem; }

    /* ── Category section ── */
    .cat-section { margin-bottom: 36px; page-break-inside: avoid; }
    .cat-title {
      font-size: 1.1rem; font-weight: 800; color: #1a1a2e;
      border-bottom: 2px solid var(--accent); padding-bottom: 8px; margin-bottom: 16px;
      display: flex; align-items: center; gap: 10px;
    }
    .cat-title img { width: 30px; height: 30px; border-radius: 50%; object-fit: cover; }

    /* ── Items grid ── */
    .items-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .item-card { border: 1px solid #eee; border-radius: 10px; overflow: hidden; page-break-inside: avoid; }
    .item-card.unavailable { opacity: .55; }
    .item-img { width: 100%; height: 90px; object-fit: cover; display: block; }
    .item-body { padding: 9px 11px 12px; }
    .item-badge { display: inline-block; font-size: .65rem; font-weight: 700; text-transform: uppercase; padding: 2px 7px; border-radius: 10px; margin-bottom: 5px; }
    .badge-spicy { background: #ff4d4d; color: #fff; }
    .badge-popular { background: #f5a623; color: #fff; }
    .badge-new { background: #00b894; color: #fff; }
    .badge-vegetarian { background: #27ae60; color: #fff; }
    .item-name { font-weight: 700; font-size: .88rem; margin-bottom: 3px; color: #1a1a2e; }
    .item-desc { font-size: .72rem; color: #999; line-height: 1.4; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .item-footer { display: flex; align-items: center; justify-content: space-between; }
    .item-price { color: var(--accent); font-weight: 800; font-size: .92rem; }
    .item-unavail { font-size: .7rem; color: #aaa; font-style: italic; }

    /* ── Footer ── */
    .print-footer { text-align: center; padding: 24px 0; border-top: 1px solid #e8e8e8; color: #bbb; font-size: .78rem; margin-top: 20px; }

    /* ── Print styles ── */
    @media print {
      .toolbar { display: none !important; }
      .page { margin-top: 0; }
      body { font-size: 11px; }
      .items-grid { grid-template-columns: repeat(3, 1fr); }
      .cat-section { page-break-inside: avoid; }
      .item-card { break-inside: avoid; }
    }

    @media (max-width: 600px) {
      .items-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

<!-- Toolbar (hidden when printing) -->
<div class="toolbar">
  <div class="toolbar-left">
    <a href="/admin/qrcode">← Back</a>
    <span style="color:rgba(255,255,255,.3)">|</span>
    <span><%= tenant.name %> — Print Menu</span>
  </div>
  <button class="print-btn" onclick="window.print()">🖨️ Print / Save PDF</button>
</div>

<div class="page">

  <!-- Header -->
  <div class="print-header">
    <% if (tenant.logo_url) { %>
      <img class="print-logo" src="<%= tenant.logo_url %>" alt="<%= tenant.name %>" />
    <% } %>
    <div class="print-name"><%= tenant.name %></div>
    <% if (tenant.description) { %><div class="print-desc"><%= tenant.description %></div><% } %>
  </div>

  <!-- Categories and items -->
  <% categories.forEach(cat => { %>
    <% const catItems = items.filter(i => Number(i.category_id) === Number(cat.id)); %>
    <% if (catItems.length === 0) return; %>
    <div class="cat-section">
      <h2 class="cat-title">
        <% if (cat.image_url) { %><img src="<%= cat.image_url %>" alt="" /><% } %>
        <%= cat.name %>
      </h2>
      <div class="items-grid">
        <% catItems.forEach(item => { %>
          <div class="item-card <%= item.is_available === false ? 'unavailable' : '' %>">
            <% if (item.image_url) { %>
              <img class="item-img" src="<%= item.image_url %>" alt="<%= item.name %>" />
            <% } %>
            <div class="item-body">
              <% if (item.badge) { %>
                <span class="item-badge badge-<%= item.badge %>"><%= item.badge %></span>
              <% } %>
              <div class="item-name"><%= item.name %></div>
              <% if (item.description) { %><div class="item-desc"><%= item.description %></div><% } %>
              <div class="item-footer">
                <span class="item-price"><%= item.price %></span>
                <% if (item.is_available === false) { %><span class="item-unavail">Unavailable</span><% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% }) %>

  <div class="print-footer">MenuApp &nbsp;·&nbsp; <%= tenant.name %></div>
</div>

</body>
</html>

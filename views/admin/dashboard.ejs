<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; color: #222; }

    /* Top bar */
    header {
      background: #1a1a2e; color: #fff;
      padding: 16px 32px; display: flex;
      justify-content: space-between; align-items: center;
    }
    header h1 { font-size: 1.2rem; }
    header a { color: #e94560; font-size: .9rem; text-decoration: none; }
    header a:hover { text-decoration: underline; }

    .container { max-width: 960px; margin: 32px auto; padding: 0 20px; }

    /* Section cards */
    .section {
      background: #fff; border-radius: 12px;
      padding: 24px; margin-bottom: 28px;
      box-shadow: 0 2px 8px rgba(0,0,0,.07);
    }
    .section h2 { font-size: 1.1rem; margin-bottom: 18px; color: #1a1a2e; }

    /* Form rows */
    .form-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
    .form-row input, .form-row select, .form-row textarea {
      flex: 1; min-width: 140px; padding: 9px 12px;
      border: 1px solid #ddd; border-radius: 8px; font-size: .9rem; outline: none;
    }
    .form-row input:focus, .form-row select:focus, .form-row textarea:focus {
      border-color: #e94560;
    }
    textarea { resize: vertical; min-height: 72px; }

    .btn { padding: 9px 20px; border: none; border-radius: 8px; cursor: pointer; font-size: .9rem; font-weight: 600; }
    .btn-primary { background: #e94560; color: #fff; }
    .btn-primary:hover { background: #c73652; }
    .btn-danger  { background: #fee; color: #e94560; border: 1px solid #f5c2cb; }
    .btn-danger:hover { background: #fdd; }
    .btn-edit { background: #eef; color: #16213e; border: 1px solid #ccd; }
    .btn-edit:hover { background: #dde; }

    /* Items table */
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    th { text-align: left; padding: 10px 12px; background: #f9f9f9; color: #555; font-weight: 600; border-bottom: 2px solid #eee; }
    td { padding: 12px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
    td img { width: 52px; height: 40px; object-fit: cover; border-radius: 6px; }
    tr:last-child td { border-bottom: none; }

    /* Categories list */
    .cat-list { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
    .cat-tag {
      display: flex; align-items: center; gap: 8px;
      background: #f0f0f0; border-radius: 20px; padding: 6px 14px; font-size: .88rem;
    }
    .cat-tag form { margin: 0; }

    /* Edit modal */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
    .overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 14px; padding: 28px; width: 100%; max-width: 500px; }
    .modal h3 { margin-bottom: 16px; color: #1a1a2e; }
    .modal .form-row { margin-bottom: 10px; }
    .modal-actions { display: flex; gap: 10px; margin-top: 16px; justify-content: flex-end; }
  </style>
</head>
<body>

<header>
  <h1>🍽️ <%= tenant.name %> — Admin</h1>
  <div style="display:flex;gap:20px;align-items:center">
    <a href="/?tenant=<%= tenant.subdomain %>" target="_blank">View Menu ↗</a>
    <form method="POST" action="/admin/logout" style="margin:0">
      <button class="btn btn-danger" style="padding:6px 14px">Logout</button>
    </form>
  </div>
</header>

<div class="container">

  <!-- Categories -->
  <div class="section">
    <h2>Categories</h2>
    <div class="cat-list">
      <% categories.forEach(cat => { %>
        <div class="cat-tag">
          <%= cat.name %>
          <form method="POST" action="/admin/categories/<%= cat.id %>/delete" onsubmit="return confirm('Delete this category?')">
            <button class="btn btn-danger" style="padding:2px 8px;font-size:.8rem">✕</button>
          </form>
        </div>
      <% }) %>
    </div>
    <form method="POST" action="/admin/categories">
      <div class="form-row">
        <input type="text" name="name" placeholder="New category name" required />
        <button class="btn btn-primary" type="submit">Add Category</button>
      </div>
    </form>
  </div>

  <!-- Add Item -->
  <div class="section">
    <h2>Add New Item</h2>
    <form method="POST" action="/admin/items">
      <div class="form-row">
        <input type="text" name="name" placeholder="Item name" required />
        <input type="text" name="price" placeholder="Price (e.g. $9.99)" required />
        <select name="category_id" required>
          <option value="">Select category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <textarea name="description" placeholder="Description"></textarea>
      </div>
      <div class="form-row">
        <input type="url" name="image_url" placeholder="Image URL (optional)" />
        <button class="btn btn-primary" type="submit">Add Item</button>
      </div>
    </form>
  </div>

  <!-- Items List -->
  <div class="section">
    <h2>Menu Items (<%= items.length %>)</h2>
    <% if (items.length === 0) { %>
      <p style="color:#aaa;text-align:center;padding:24px 0">No items yet. Add one above.</p>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Price</th>
          <th>Category</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(item => { %>
        <tr>
          <td><img src="<%= item.image_url || 'https://placehold.co/52x40?text=?' %>" alt="<%= item.name %>" /></td>
          <td><strong><%= item.name %></strong><br><small style="color:#aaa"><%= (item.description || '').substring(0, 50) %><%= item.description && item.description.length > 50 ? '…' : '' %></small></td>
          <td><%= item.price %></td>
          <td><%= item.category_name || '—' %></td>
          <td style="display:flex;gap:8px;align-items:center;padding-top:14px">
            <button class="btn btn-edit" onclick='openEdit(<%- JSON.stringify(item) %>)'>Edit</button>
            <form method="POST" action="/admin/items/<%= item.id %>/delete" onsubmit="return confirm('Delete this item?')" style="margin:0">
              <button class="btn btn-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

</div>

<!-- Edit Modal -->
<div class="overlay" id="editOverlay">
  <div class="modal">
    <h3>Edit Item</h3>
    <form method="POST" id="editForm">
      <div class="form-row">
        <input type="text" name="name" id="editName" placeholder="Item name" required />
        <input type="text" name="price" id="editPrice" placeholder="Price" required />
      </div>
      <div class="form-row">
        <select name="category_id" id="editCategory" required>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <textarea name="description" id="editDescription" placeholder="Description"></textarea>
      </div>
      <div class="form-row">
        <input type="url" name="image_url" id="editImageUrl" placeholder="Image URL" />
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-edit" onclick="closeEdit()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEdit(item) {
    document.getElementById('editName').value = item.name;
    document.getElementById('editPrice').value = item.price;
    document.getElementById('editDescription').value = item.description || '';
    document.getElementById('editImageUrl').value = item.image_url || '';
    document.getElementById('editCategory').value = item.category_id || '';
    document.getElementById('editForm').action = '/admin/items/' + item.id + '/edit';
    document.getElementById('editOverlay').classList.add('open');
  }

  function closeEdit() {
    document.getElementById('editOverlay').classList.remove('open');
  }

  document.getElementById('editOverlay').addEventListener('click', e => {
    if (e.target === document.getElementById('editOverlay')) closeEdit();
  });
</script>

</body>
</html>

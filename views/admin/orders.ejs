<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orders — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --accent: <%= tenant.theme_color || '#e94560' %>; --sidebar-w: 240px; }
    body { font-family: 'Segoe UI', sans-serif; background: #f4f5f7; color: #222; display: flex; min-height: 100vh; }

    .sidebar {
      width: var(--sidebar-w); background: #1a1a2e;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; padding: 0 0 24px;
    }
    .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap: 12px; }
    .sidebar-brand .brand-emoji { font-size: 1.6rem; }
    .sidebar-brand-text h2 { color: #fff; font-size: .95rem; font-weight: 700; line-height: 1.2; }
    .sidebar-brand-text span { color: #aaa; font-size: .75rem; }
    .sidebar-nav { flex: 1; padding: 16px 12px; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-nav a, .sidebar-nav button {
      display: flex; align-items: center; gap: 10px; padding: 11px 14px;
      border-radius: 10px; color: #aaa; text-decoration: none; font-size: .9rem;
      background: none; border: none; cursor: pointer; width: 100%;
      transition: background .15s, color .15s; font-family: inherit;
    }
    .sidebar-nav a:hover, .sidebar-nav button:hover { background: rgba(255,255,255,.07); color: #fff; }
    .sidebar-nav a.active { background: var(--accent); color: #fff; font-weight: 600; }
    .sidebar-nav .icon { font-size: 1.1rem; width: 20px; text-align: center; }
    .sidebar-footer { padding: 0 12px; }
    .view-menu-btn { display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(255,255,255,.07); color: #ccc; padding: 10px; border-radius: 10px; text-decoration: none; font-size: .85rem; transition: background .15s; }
    .view-menu-btn:hover { background: rgba(255,255,255,.14); color: #fff; }

    .main { margin-left: var(--sidebar-w); flex: 1; padding: 32px; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; }
    .page-header p { color: #888; font-size: .9rem; margin-top: 4px; }

    .card { background: #fff; border-radius: 14px; padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .card-header h2 { font-size: 1rem; font-weight: 700; color: #1a1a2e; }

    .orders-table { width: 100%; border-collapse: collapse; }
    .orders-table th { text-align: left; padding: 10px 14px; font-size: .78rem; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: .5px; border-bottom: 2px solid #f0f0f0; background: #fafafa; }
    .orders-table td { padding: 14px; border-bottom: 1px solid #f5f5f5; vertical-align: top; font-size: .88rem; }
    .orders-table tr:last-child td { border-bottom: none; }
    .orders-table tr:hover td { background: #fafcff; }

    .order-time { color: #888; font-size: .78rem; }
    .order-customer { font-weight: 600; color: #1a1a2e; }
    .order-table-no { color: #888; font-size: .8rem; margin-top: 2px; }
    .order-items { color: #555; font-size: .82rem; line-height: 1.6; }
    .order-count { display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: #fff; border-radius: 20px; padding: 2px 10px; font-size: .75rem; font-weight: 700; }

    .empty-state { text-align: center; padding: 64px 0; color: #bbb; }
    .empty-state p { margin-top: 12px; font-size: .95rem; }

    @media (max-width: 768px) {
      .sidebar { width: 64px; }
      .sidebar-brand-text, .sidebar-nav span:not(.icon) { display: none; }
      .main { margin-left: 64px; padding: 20px 16px; }
    }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <% if (tenant.logo_url) { %>
      <img src="<%= tenant.logo_url %>" alt="" style="width:40px;height:40px;border-radius:10px;object-fit:cover" />
    <% } else { %>
      <span class="brand-emoji">🍽️</span>
    <% } %>
    <div class="sidebar-brand-text">
      <h2><%= tenant.name %></h2>
      <span>Admin Panel</span>
    </div>
  </div>
  <nav class="sidebar-nav">
    <% const _isAdmin = currentUser && currentUser.role === 'admin'; const _perms = (currentUser && currentUser.permissions) || []; const _can = p => _isAdmin || _perms.includes(p); %>
    <% if (_can('items')) { %><a href="/admin/dashboard"><span class="icon">📊</span><span>Dashboard</span></a><% } %>
    <% if (_can('orders') && tenant.feat_orders !== false) { %><a href="/admin/orders" class="active"><span class="icon">📋</span><span>Orders</span></a><% } %>
    <% if (_can('feedback') && tenant.feat_feedback !== false) { %><a href="/admin/feedback"><span class="icon">💬</span><span>Feedback</span></a><% } %>
    <% if (_can('import') && tenant.feat_import !== false) { %><a href="/admin/import"><span class="icon">📥</span><span>Import</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/qrcode"><span class="icon">📱</span><span>QR Code</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/users"><span class="icon">👥</span><span>Users</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/settings"><span class="icon">⚙️</span><span>Settings</span></a><% } %>
    <form method="POST" action="/admin/logout" style="margin-top:auto">
      <button type="submit"><span class="icon">🚪</span><span>Logout</span></button>
    </form>
  </nav>
  <div class="sidebar-footer">
    <a href="/?tenant=<%= tenant.subdomain %>" target="_blank" class="view-menu-btn">
      <span>🔗</span><span>View Menu</span>
    </a>
  </div>
</aside>

<div class="main">
  <div class="page-header">
    <h1>Order History</h1>
    <p>Every WhatsApp order placed through your menu — <%= orders.length %> total</p>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Recent Orders</h2>
      <span style="color:#aaa;font-size:.85rem">Last 200</span>
    </div>

    <% if (orders.length === 0) { %>
      <div class="empty-state">
        <div style="font-size:3rem">📋</div>
        <p>No orders yet. Orders appear here when customers place them via WhatsApp.</p>
      </div>
    <% } else { %>
    <div style="overflow-x:auto">
      <table class="orders-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Customer</th>
            <th>Items</th>
            <th>Count</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
          <tr>
            <td>
              <div class="order-time">
                <%= new Date(order.created_at).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
              </div>
              <div class="order-time">
                <%= new Date(order.created_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
              </div>
            </td>
            <td>
              <div class="order-customer"><%= order.customer_name || '—' %></div>
              <% if (order.table_no) { %>
                <div class="order-table-no">Table <%= order.table_no %></div>
              <% } %>
            </td>
            <td>
              <div class="order-items">
                <% if (order.items && order.items.length > 0) { %>
                  <% order.items.forEach(i => { %>
                    <%= i.name %> ×<%= i.qty %><br/>
                  <% }) %>
                <% } else { %>
                  —
                <% } %>
              </div>
            </td>
            <td>
              <span class="order-count"><%= order.item_count || 0 %></span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Feedback — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --accent: <%= tenant.theme_color || '#e94560' %>; --sidebar-w: 240px; }
    body { font-family: 'Segoe UI', sans-serif; background: #f4f5f7; color: #222; display: flex; min-height: 100vh; }

    .sidebar {
      width: var(--sidebar-w); background: #1a1a2e;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; padding: 0 0 24px;
    }
    .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap: 12px; }
    .sidebar-brand .brand-emoji { font-size: 1.6rem; }
    .sidebar-brand-text h2 { color: #fff; font-size: .95rem; font-weight: 700; line-height: 1.2; }
    .sidebar-brand-text span { color: #aaa; font-size: .75rem; }
    .sidebar-nav { flex: 1; padding: 16px 12px; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-nav a, .sidebar-nav button {
      display: flex; align-items: center; gap: 10px; padding: 11px 14px;
      border-radius: 10px; color: #aaa; text-decoration: none; font-size: .9rem;
      background: none; border: none; cursor: pointer; width: 100%;
      transition: background .15s, color .15s; font-family: inherit;
    }
    .sidebar-nav a:hover, .sidebar-nav button:hover { background: rgba(255,255,255,.07); color: #fff; }
    .sidebar-nav a.active { background: var(--accent); color: #fff; font-weight: 600; }
    .sidebar-nav .icon { font-size: 1.1rem; width: 20px; text-align: center; }
    .sidebar-footer { padding: 0 12px; }
    .view-menu-btn { display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(255,255,255,.07); color: #ccc; padding: 10px; border-radius: 10px; text-decoration: none; font-size: .85rem; transition: background .15s; }
    .view-menu-btn:hover { background: rgba(255,255,255,.14); color: #fff; }

    .main { margin-left: var(--sidebar-w); flex: 1; padding: 32px; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; }
    .page-header p { color: #888; font-size: .9rem; margin-top: 4px; }

    /* Summary cards */
    .summary-row { display: flex; gap: 14px; margin-bottom: 24px; flex-wrap: wrap; }
    .summary-card { background: #fff; border-radius: 14px; padding: 18px 20px; box-shadow: 0 2px 8px rgba(0,0,0,.06); flex: 1; min-width: 120px; }
    .s-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #aaa; margin-bottom: 5px; }
    .s-val { font-size: 1.7rem; font-weight: 800; color: #1a1a2e; }
    .s-stars { color: #f5a623; font-size: .95rem; margin-top: 2px; }

    /* Per-question averages */
    .q-avg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .q-avg-card { background: #fff; border-radius: 12px; padding: 14px 16px; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
    .q-avg-label { font-size: .78rem; font-weight: 700; color: #555; margin-bottom: 6px; }
    .q-avg-bar-wrap { background: #f0f0f0; border-radius: 99px; height: 6px; margin-bottom: 4px; }
    .q-avg-bar { background: #f5a623; border-radius: 99px; height: 6px; transition: width .4s; }
    .q-avg-num { font-size: .8rem; font-weight: 700; color: #f5a623; }

    .card { background: #fff; border-radius: 14px; padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .card-header h2 { font-size: 1rem; font-weight: 700; color: #1a1a2e; }

    /* Review cards */
    .review-list { display: flex; flex-direction: column; gap: 14px; }
    .review-card { border: 1.5px solid #f0f0f0; border-radius: 14px; padding: 18px 20px; }
    .review-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
    .review-customer { display: flex; flex-direction: column; gap: 2px; }
    .review-name { font-weight: 700; font-size: .95rem; color: #1a1a2e; }
    .review-meta { font-size: .78rem; color: #aaa; display: flex; gap: 10px; flex-wrap: wrap; }
    .review-time { font-size: .78rem; color: #bbb; white-space: nowrap; }
    .review-questions { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px; margin-bottom: 10px; }
    .review-q { background: #fafafa; border-radius: 8px; padding: 8px 10px; }
    .review-q-label { font-size: .72rem; color: #888; margin-bottom: 3px; }
    .review-q-stars { color: #f5a623; font-size: .9rem; letter-spacing: 1px; }
    .review-comment { font-size: .85rem; color: #555; font-style: italic; padding-top: 8px; border-top: 1px solid #f5f5f5; margin-top: 8px; }

    .empty-state { text-align: center; padding: 64px 0; color: #bbb; }
    .empty-state p { margin-top: 12px; font-size: .95rem; }

    @media (max-width: 768px) {
      .sidebar { width: 64px; }
      .sidebar-brand-text, .sidebar-nav span:not(.icon) { display: none; }
      .main { margin-left: 64px; padding: 20px 16px; }
    }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <% if (tenant.logo_url) { %>
      <img src="<%= tenant.logo_url %>" alt="" style="width:40px;height:40px;border-radius:10px;object-fit:cover" />
    <% } else { %>
      <span class="brand-emoji">🍽️</span>
    <% } %>
    <div class="sidebar-brand-text">
      <h2><%= tenant.name %></h2>
      <span>Admin Panel</span>
    </div>
  </div>
  <nav class="sidebar-nav">
    <a href="/admin/dashboard"><span class="icon">📊</span><span>Dashboard</span></a>
    <a href="/admin/orders"><span class="icon">📋</span><span>Orders</span></a>
    <a href="/admin/feedback" class="active"><span class="icon">💬</span><span>Feedback</span></a>
    <a href="/admin/qrcode"><span class="icon">📱</span><span>QR Code</span></a>
    <a href="/admin/settings"><span class="icon">⚙️</span><span>Settings</span></a>
    <form method="POST" action="/admin/logout" style="margin-top:auto">
      <button type="submit"><span class="icon">🚪</span><span>Logout</span></button>
    </form>
  </nav>
  <div class="sidebar-footer">
    <a href="/?tenant=<%= tenant.subdomain %>" target="_blank" class="view-menu-btn">
      <span>🔗</span><span>View Menu</span>
    </a>
  </div>
</aside>

<div class="main">
  <div class="page-header">
    <h1>Customer Feedback</h1>
    <p><%= feedback.length %> review<%= feedback.length !== 1 ? 's' : '' %> received</p>
  </div>

  <%
    const total = feedback.length;
    function qAvg(key) {
      const vals = feedback.map(f => f[key]).filter(v => v != null && v > 0);
      return vals.length ? (vals.reduce((a,b) => a+b,0) / vals.length) : 0;
    }
    const overallAvg = qAvg('rating') || (qAvg('q5') || ((qAvg('q1')+qAvg('q2')+qAvg('q3')+qAvg('q4')+qAvg('q5'))/5));
    const questions = [
      { key: 'q1', label: '🍽️ Food Quality' },
      { key: 'q2', label: '🙋 Service' },
      { key: 'q3', label: '🏡 Atmosphere' },
      { key: 'q4', label: '💰 Value for Money' },
      { key: 'q5', label: '⭐ Overall Experience' },
    ];
  %>

  <% if (total > 0) { %>
  <div class="summary-row">
    <div class="summary-card">
      <div class="s-label">Overall Avg</div>
      <div class="s-val"><%= overallAvg.toFixed(1) %></div>
      <div class="s-stars"><% for(let i=1;i<=5;i++){%><%= i<=Math.round(overallAvg)?'★':'☆'%><%}%></div>
    </div>
    <div class="summary-card">
      <div class="s-label">Total Reviews</div>
      <div class="s-val"><%= total %></div>
    </div>
  </div>

  <div class="q-avg-grid">
    <% questions.forEach(q => {
      const avg = qAvg(q.key);
      const pct = (avg / 5 * 100).toFixed(0);
    %>
    <div class="q-avg-card">
      <div class="q-avg-label"><%= q.label %></div>
      <div class="q-avg-bar-wrap"><div class="q-avg-bar" style="width:<%= pct %>%"></div></div>
      <div class="q-avg-num"><%= avg > 0 ? avg.toFixed(1) + ' / 5' : '—' %></div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <div class="card">
    <div class="card-header">
      <h2>All Reviews</h2>
      <span style="color:#aaa;font-size:.85rem">Newest first</span>
    </div>

    <% if (feedback.length === 0) { %>
      <div class="empty-state">
        <div style="font-size:3rem">💬</div>
        <p>No feedback yet. It will appear here once customers submit reviews.</p>
      </div>
    <% } else { %>
    <div class="review-list">
      <% feedback.forEach(f => { %>
      <div class="review-card">
        <div class="review-top">
          <div class="review-customer">
            <div class="review-name"><%= f.customer_name || 'Anonymous' %></div>
            <div class="review-meta">
              <% if (f.mobile) { %><span>📞 <%= f.mobile %></span><% } %>
              <% if (f.table_no) { %><span>🪑 Table <%= f.table_no %></span><% } %>
            </div>
          </div>
          <div class="review-time">
            <%= new Date(f.created_at).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
            <%= new Date(f.created_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
          </div>
        </div>

        <div class="review-questions">
          <% questions.forEach(q => { const r = f[q.key]; if (!r) return; %>
          <div class="review-q">
            <div class="review-q-label"><%= q.label %></div>
            <div class="review-q-stars">
              <%= '★'.repeat(r) %><%= '☆'.repeat(5-r) %>
            </div>
          </div>
          <% }) %>
        </div>

        <% if (f.comment) { %>
        <div class="review-comment">"<%= f.comment %>"</div>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Import Items — <%= tenant.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --accent: <%= tenant.theme_color || '#e94560' %>; --sidebar-w: 240px; }
    body { font-family: 'Segoe UI', sans-serif; background: #f4f5f7; color: #222; display: flex; min-height: 100vh; }

    .sidebar { width: var(--sidebar-w); background: #1a1a2e; display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; padding: 0 0 24px; }
    .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap: 12px; }
    .sidebar-brand .brand-emoji { font-size: 1.6rem; }
    .sidebar-brand-text h2 { color: #fff; font-size: .95rem; font-weight: 700; line-height: 1.2; }
    .sidebar-brand-text span { color: #aaa; font-size: .75rem; }
    .sidebar-nav { flex: 1; padding: 16px 12px; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-nav a, .sidebar-nav button { display: flex; align-items: center; gap: 10px; padding: 11px 14px; border-radius: 10px; color: #aaa; text-decoration: none; font-size: .9rem; background: none; border: none; cursor: pointer; width: 100%; transition: background .15s, color .15s; font-family: inherit; }
    .sidebar-nav a:hover, .sidebar-nav button:hover { background: rgba(255,255,255,.07); color: #fff; }
    .sidebar-nav a.active { background: var(--accent); color: #fff; font-weight: 600; }
    .sidebar-nav .icon { font-size: 1.1rem; width: 20px; text-align: center; }
    .sidebar-footer { padding: 0 12px; }
    .view-menu-btn { display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(255,255,255,.07); color: #ccc; padding: 10px; border-radius: 10px; text-decoration: none; font-size: .85rem; transition: background .15s; }
    .view-menu-btn:hover { background: rgba(255,255,255,.14); color: #fff; }

    .main { margin-left: var(--sidebar-w); flex: 1; padding: 32px; max-width: 900px; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; }
    .page-header p { color: #888; font-size: .9rem; margin-top: 4px; }

    .card { background: #fff; border-radius: 14px; padding: 28px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .card h2 { font-size: 1rem; font-weight: 700; color: #1a1a2e; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid #f0f0f0; }

    /* Template download */
    .template-info { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .template-info p { font-size: .88rem; color: #555; line-height: 1.6; }
    .btn-download { display: inline-flex; align-items: center; gap: 8px; background: #16a34a; color: #fff; padding: 10px 18px; border-radius: 10px; text-decoration: none; font-size: .88rem; font-weight: 700; white-space: nowrap; transition: opacity .15s; }
    .btn-download:hover { opacity: .88; }

    /* Column table */
    .col-table { width: 100%; border-collapse: collapse; font-size: .83rem; margin-bottom: 6px; }
    .col-table th { background: #f8f8f8; text-align: left; padding: 8px 12px; color: #555; font-weight: 700; border-bottom: 2px solid #f0f0f0; }
    .col-table td { padding: 8px 12px; border-bottom: 1px solid #f5f5f5; color: #444; }
    .col-table tr:last-child td { border-bottom: none; }
    .badge-req { background: #fee2e2; color: #991b1b; font-size: .7rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; }
    .badge-opt { background: #f0f9ff; color: #0369a1; font-size: .7rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; }

    /* Upload zone */
    .upload-zone {
      border: 2.5px dashed #e0e0e0; border-radius: 14px; padding: 40px 24px;
      text-align: center; cursor: pointer; transition: border-color .2s, background .2s;
      background: #fafafa;
    }
    .upload-zone:hover, .upload-zone.drag { border-color: var(--accent); background: rgba(233,69,96,.04); }
    .upload-zone .uz-icon { font-size: 2.5rem; margin-bottom: 10px; }
    .upload-zone p { font-size: .9rem; color: #555; margin-bottom: 6px; }
    .upload-zone small { font-size: .78rem; color: #aaa; }
    .upload-zone input[type=file] { display: none; }
    .file-chosen { margin-top: 12px; font-size: .85rem; font-weight: 600; color: #16a34a; }

    .btn-import { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: #fff; padding: 12px 28px; border: none; border-radius: 10px; font-size: .95rem; font-weight: 700; cursor: pointer; font-family: inherit; transition: opacity .15s; margin-top: 18px; }
    .btn-import:hover { opacity: .88; }
    .btn-import:disabled { opacity: .5; cursor: default; }

    /* Results */
    .result-banner { padding: 14px 18px; border-radius: 10px; font-size: .9rem; font-weight: 600; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .result-banner.success { background: #dcfce7; color: #166534; }
    .result-banner.error   { background: #fee2e2; color: #991b1b; }
    .result-banner.partial { background: #fef9c3; color: #854d0e; }

    .result-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
    .result-table th { text-align: left; padding: 8px 12px; font-size: .74rem; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: .4px; border-bottom: 2px solid #f0f0f0; background: #fafafa; }
    .result-table td { padding: 10px 12px; border-bottom: 1px solid #f5f5f5; vertical-align: top; }
    .result-table tr:last-child td { border-bottom: none; }
    .row-ok  { color: #16a34a; font-weight: 700; }
    .row-err { color: #dc2626; font-weight: 700; }

    @media (max-width: 768px) {
      .sidebar { width: 64px; }
      .sidebar-brand-text, .sidebar-nav span:not(.icon) { display: none; }
      .main { margin-left: 64px; padding: 16px; }
    }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <% if (tenant.logo_url) { %>
      <img src="<%= tenant.logo_url %>" alt="" style="width:40px;height:40px;border-radius:10px;object-fit:cover" />
    <% } else { %>
      <span class="brand-emoji">🍽️</span>
    <% } %>
    <div class="sidebar-brand-text">
      <h2><%= tenant.name %></h2>
      <span>Admin Panel</span>
    </div>
  </div>
  <nav class="sidebar-nav">
    <% const _isAdmin = currentUser && currentUser.role === 'admin'; const _perms = (currentUser && currentUser.permissions) || []; const _can = p => _isAdmin || _perms.includes(p); %>
    <% if (_can('items')) { %><a href="/admin/dashboard"><span class="icon">📊</span><span>Dashboard</span></a><% } %>
    <% if (_can('orders') && tenant.feat_orders !== false) { %><a href="/admin/orders"><span class="icon">📋</span><span>Orders</span></a><% } %>
    <% if (_can('feedback') && tenant.feat_feedback !== false) { %><a href="/admin/feedback"><span class="icon">💬</span><span>Feedback</span></a><% } %>
    <% if (_can('import') && tenant.feat_import !== false) { %><a href="/admin/import" class="active"><span class="icon">📥</span><span>Import</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/qrcode"><span class="icon">📱</span><span>QR Code</span></a><% } %>
    <% if (tenant.feat_pos) { %><a href="/pos"><span class="icon">🖥️</span><span>POS</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/users"><span class="icon">👥</span><span>Users</span></a><% } %>
    <% if (_isAdmin) { %><a href="/admin/settings"><span class="icon">⚙️</span><span>Settings</span></a><% } %>
    <form method="POST" action="/admin/logout" style="margin-top:auto">
      <button type="submit"><span class="icon">🚪</span><span>Logout</span></button>
    </form>
  </nav>
  <div class="sidebar-footer">
    <a href="/?tenant=<%= tenant.subdomain %>" target="_blank" class="view-menu-btn">
      <span>🔗</span><span>View Menu</span>
    </a>
  </div>
</aside>

<div class="main">
  <div class="page-header">
    <h1>Import Menu Items</h1>
    <p>Upload an Excel file to add multiple items at once</p>
  </div>

  <!-- Step 1: Template -->
  <div class="card">
    <h2>Step 1 — Download the Template</h2>
    <div class="template-info">
      <p>Fill in the Excel template with your items.<br/>
         Categories are matched by name — new ones are created automatically.</p>
      <a href="/admin/import/template" class="btn-download">⬇ Download Template (.xlsx)</a>
    </div>

    <div style="overflow-x:auto">
      <table class="col-table">
        <thead>
          <tr>
            <th>Column</th>
            <th>Description</th>
            <th>Required?</th>
            <th>Example</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><strong>name</strong></td><td>Item name (English)</td><td><span class="badge-req">Required</span></td><td>Chicken Burger</td></tr>
          <tr><td><strong>name_ar</strong></td><td>Item name (Arabic)</td><td><span class="badge-opt">Optional</span></td><td>برجر دجاج</td></tr>
          <tr><td><strong>name_ku</strong></td><td>Item name (Kurdish)</td><td><span class="badge-opt">Optional</span></td><td>برگەری مریشک</td></tr>
          <tr><td><strong>price</strong></td><td>Price (number or text)</td><td><span class="badge-req">Required</span></td><td>12.99</td></tr>
          <tr><td><strong>category</strong></td><td>Category name — created if it doesn't exist</td><td><span class="badge-opt">Optional</span></td><td>Burgers</td></tr>
          <tr><td><strong>description</strong></td><td>Description (English)</td><td><span class="badge-opt">Optional</span></td><td>Crispy fried chicken with lettuce</td></tr>
          <tr><td><strong>description_ar</strong></td><td>Description (Arabic)</td><td><span class="badge-opt">Optional</span></td><td>دجاج مقلي مع خس</td></tr>
          <tr><td><strong>description_ku</strong></td><td>Description (Kurdish)</td><td><span class="badge-opt">Optional</span></td><td>مریشکی سووتاو لەگەڵ کاڵ</td></tr>
          <tr><td><strong>image_url</strong></td><td>Image link (https://...)</td><td><span class="badge-opt">Optional</span></td><td>https://example.com/img.jpg</td></tr>
          <tr><td><strong>badge</strong></td><td>spicy / popular / new / vegetarian</td><td><span class="badge-opt">Optional</span></td><td>popular</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Step 2: Upload -->
  <div class="card">
    <h2>Step 2 — Upload Your File</h2>

    <% if (locals.result) { %>
      <div class="result-banner <%= result.errors.length === 0 ? 'success' : (result.imported > 0 ? 'partial' : 'error') %>">
        <span style="font-size:1.3rem"><%= result.errors.length === 0 ? '✅' : (result.imported > 0 ? '⚠️' : '❌') %></span>
        <span>
          <%= result.imported %> item<%= result.imported !== 1 ? 's' : '' %> imported successfully.
          <% if (result.errors.length > 0) { %> <%= result.errors.length %> row<%= result.errors.length !== 1 ? 's' : '' %> had errors and were skipped.<% } %>
        </span>
      </div>

      <% if (result.rows.length > 0) { %>
      <div style="overflow-x:auto;margin-bottom:24px">
        <table class="result-table">
          <thead>
            <tr><th>Row</th><th>Name</th><th>Category</th><th>Price</th><th>Status</th></tr>
          </thead>
          <tbody>
            <% result.rows.forEach(r => { %>
            <tr>
              <td>#<%= r.row %></td>
              <td><%= r.name || '—' %></td>
              <td><%= r.category || '—' %></td>
              <td><%= r.price || '—' %></td>
              <td class="<%= r.ok ? 'row-ok' : 'row-err' %>"><%= r.ok ? '✓ Imported' : '✗ ' + r.error %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <a href="/admin/dashboard" style="display:inline-flex;align-items:center;gap:6px;background:#1a1a2e;color:#fff;padding:10px 18px;border-radius:10px;text-decoration:none;font-size:.88rem;font-weight:700;margin-right:10px">📊 View Dashboard</a>
      <a href="/admin/import" style="display:inline-flex;align-items:center;gap:6px;background:#f4f5f7;color:#555;border:1.5px solid #e0e0e0;padding:10px 18px;border-radius:10px;text-decoration:none;font-size:.88rem;font-weight:700">↩ Import Another File</a>
    <% } else { %>

    <form method="POST" action="/admin/import" enctype="multipart/form-data" id="importForm">
      <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()"
           ondragover="event.preventDefault();this.classList.add('drag')"
           ondragleave="this.classList.remove('drag')"
           ondrop="handleDrop(event)">
        <div class="uz-icon">📊</div>
        <p>Click to choose a file, or drag & drop here</p>
        <small>Accepts .xlsx and .xls files</small>
        <div class="file-chosen" id="fileChosen" style="display:none"></div>
        <input type="file" id="fileInput" name="file" accept=".xlsx,.xls" onchange="fileSelected(this)" />
      </div>
      <button type="submit" class="btn-import" id="importBtn" disabled>📥 Import Items</button>
    </form>
    <% } %>
  </div>
</div>

<script>
  function fileSelected(input) {
    if (input.files.length) {
      document.getElementById('fileChosen').textContent = '✓ ' + input.files[0].name;
      document.getElementById('fileChosen').style.display = 'block';
      document.getElementById('importBtn').disabled = false;
    }
  }
  function handleDrop(e) {
    e.preventDefault();
    document.getElementById('uploadZone').classList.remove('drag');
    const dt = e.dataTransfer;
    if (dt.files.length) {
      document.getElementById('fileInput').files = dt.files;
      fileSelected(document.getElementById('fileInput'));
    }
  }
  document.getElementById('importForm') && document.getElementById('importForm').addEventListener('submit', () => {
    document.getElementById('importBtn').disabled = true;
    document.getElementById('importBtn').textContent = '⏳ Importing...';
  });
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= tenant.name %></title>
  <% const _theme = tenant.menu_style || 'dark'; const _layout = tenant.menu_layout || 'grid'; const _font = tenant.menu_font || 'default';
     let _navBg = null;
     if (tenant.nav_bg_color) {
       const _hex = tenant.nav_bg_color.replace('#','');
       const _r = parseInt(_hex.substring(0,2),16), _g = parseInt(_hex.substring(2,4),16), _b = parseInt(_hex.substring(4,6),16);
       const _a = ((tenant.nav_bg_opacity != null ? tenant.nav_bg_opacity : 90)) / 100;
       _navBg = `rgba(${_r},${_g},${_b},${_a})`;
     }
     const _fbQ = {
       en: [tenant.fb_q1_en||'Food Quality', tenant.fb_q2_en||'Service', tenant.fb_q3_en||'Atmosphere', tenant.fb_q4_en||'Value for Money', tenant.fb_q5_en||'Overall Experience'],
       ar: [tenant.fb_q1_ar||'جودة الطعام', tenant.fb_q2_ar||'الخدمة', tenant.fb_q3_ar||'الأجواء', tenant.fb_q4_ar||'القيمة مقابل السعر', tenant.fb_q5_ar||'التجربة العامة'],
       ku: [tenant.fb_q1_ku||'چێژی خواردن', tenant.fb_q2_ku||'خزمەتگوزاری', tenant.fb_q3_ku||'ژینگەکە', tenant.fb_q4_ku||'کار لە بەرانبەر نرخ', tenant.fb_q5_ku||'کۆی ئەزموون'],
     };
  %>
  <% if (_font === 'elegant') { %><link rel="preconnect" href="https://fonts.googleapis.com" /><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800&display=swap" rel="stylesheet" /><% } %>
  <% if (_font === 'rounded') { %><link rel="preconnect" href="https://fonts.googleapis.com" /><link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" /><% } %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Theme Variables ── */
    :root {
      --accent: <%= tenant.theme_color || '#e94560' %>;
      <% if (_font === 'elegant') { %>
        --font: 'Playfair Display', Georgia, serif;
      <% } else if (_font === 'rounded') { %>
        --font: 'Nunito', 'Trebuchet MS', system-ui, sans-serif;
      <% } else { %>
        --font: 'Segoe UI', system-ui, -apple-system, Arial, sans-serif;
      <% } %>
      <% if (_theme === 'light') { %>
        --page-bg: #f5f6fa; --content-bg: #f5f6fa;
        --header-bg: rgba(20,20,40,0.75); --nav-bg: rgba(255,255,255,0.97);
        --nav-shadow: 0 1px 0 rgba(0,0,0,0.07),0 2px 12px rgba(0,0,0,0.04);
        --nav-text: rgba(30,30,50,0.50); --nav-hover: #1a1a2e;
        --border: rgba(0,0,0,0.07); --cat-bg: rgba(0,0,0,0.05);
        --cat-border: rgba(0,0,0,0.12); --cat-border-hover: rgba(0,0,0,0.30);
        --search-bg: #ffffff; --search-text: #1a1a2e;
        --search-ph: rgba(30,30,50,0.35); --search-border: rgba(0,0,0,0.12);
        --section-title: #1a1a2e; --section-border: rgba(0,0,0,0.10);
        --empty-color: rgba(0,0,0,0.35); --footer-color: rgba(0,0,0,0.35);
        --card-shadow: 0 2px 12px rgba(0,0,0,0.07); --card-border: rgba(0,0,0,0.07);
        --page-overlay: rgba(0,0,0,0.18);
      <% } else if (_theme === 'warm') { %>
        --page-bg: #faf8f3; --content-bg: #faf8f3;
        --header-bg: rgba(20,12,5,0.72); --nav-bg: rgba(250,248,243,0.97);
        --nav-shadow: 0 1px 0 rgba(180,140,60,0.10),0 2px 12px rgba(100,70,20,0.06);
        --nav-text: rgba(60,40,15,0.50); --nav-hover: #3b2a0e;
        --border: rgba(180,140,60,0.14); --cat-bg: rgba(180,140,60,0.08);
        --cat-border: rgba(180,140,60,0.22); --cat-border-hover: rgba(180,140,60,0.50);
        --search-bg: #fff8ef; --search-text: #3b2a0e;
        --search-ph: rgba(60,40,15,0.38); --search-border: rgba(180,140,60,0.20);
        --section-title: #3b2a0e; --section-border: rgba(180,140,60,0.20);
        --empty-color: rgba(60,40,15,0.38); --footer-color: rgba(60,40,15,0.38);
        --card-shadow: 0 2px 16px rgba(100,70,20,0.10); --card-border: rgba(180,140,60,0.12);
        --page-overlay: rgba(0,0,0,0.22);
      <% } else { %>
        --page-bg: #0f1117; --content-bg: transparent;
        --header-bg: rgba(15,17,23,0.80); --nav-bg: rgba(15,17,23,0.92);
        --nav-shadow: none;
        --nav-text: rgba(255,255,255,0.55); --nav-hover: #ffffff;
        --border: rgba(255,255,255,0.08); --cat-bg: rgba(255,255,255,0.10);
        --cat-border: rgba(255,255,255,0.20); --cat-border-hover: rgba(255,255,255,0.55);
        --search-bg: rgba(255,255,255,0.12); --search-text: #ffffff;
        --search-ph: rgba(255,255,255,0.45); --search-border: rgba(255,255,255,0.15);
        --section-title: #ffffff; --section-border: rgba(255,255,255,0.12);
        --empty-color: rgba(255,255,255,0.50); --footer-color: rgba(255,255,255,0.40);
        --card-shadow: 0 4px 20px rgba(0,0,0,0.22); --card-border: transparent;
        --page-overlay: rgba(0,0,0,0.30);
      <% } %>
      <% if (_navBg) { %>--nav-bg: <%= _navBg %>;<% } %>
    }

    body { font-family: var(--font); color: #1a1a2e; min-height: 100vh; background: var(--page-bg); }

    /* ── Background ── */
    .page-bg { position: fixed; inset: 0; z-index: 0; overflow: hidden; }
    .page-bg-img, .page-bg-video { width: 100%; height: 100%; object-fit: cover; display: block; }
    .page-bg-overlay { position: absolute; inset: 0; background: var(--page-overlay); }
    .page-content { position: relative; z-index: 1; min-height: 100vh; }
    .content-sheet { background: var(--content-bg); }

    /* ── Nav Controls (globe + valet) ── */
    .nav-controls {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px 0;
      justify-content: flex-end;
    }
    .nav-icon-btn {
      background: var(--cat-bg); border: 1.5px solid var(--cat-border);
      color: var(--nav-hover); border-radius: 50%; width: 34px; height: 34px;
      display: flex; align-items: center; justify-content: center; font-size: 1rem;
      cursor: pointer; transition: background .2s, transform .15s; flex-shrink: 0;
    }
    .nav-icon-btn:hover { background: var(--cat-border); transform: scale(1.08); }

    /* ── Sticky Nav ── */
    .sticky-wrap { position: sticky; top: 0; z-index: 50; }
    nav {
      display: flex; gap: 4px; padding: 0 20px; overflow-x: auto; scrollbar-width: none;
      background: var(--nav-bg); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border); box-shadow: var(--nav-shadow);
    }
    nav::-webkit-scrollbar { display: none; }
    nav button {
      background: none; border: none; color: var(--nav-text);
      font-size: .8rem; padding: 10px 12px; cursor: pointer;
      border-bottom: 3px solid transparent; white-space: nowrap;
      font-weight: 600; transition: color .2s, border-color .2s; font-family: inherit;
      display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    nav button:hover { color: var(--nav-hover); }
    nav button.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 700; }
    .cat-img-wrap {
      width: 46px; height: 46px; border-radius: 50%; overflow: hidden;
      border: 2px solid var(--cat-border); background: var(--cat-bg);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; transition: border-color .2s; flex-shrink: 0;
    }
    nav button.active .cat-img-wrap { border-color: var(--accent); }
    nav button:hover .cat-img-wrap { border-color: var(--cat-border-hover); }
    .cat-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* ── Toolbar ── */
    .toolbar { max-width: 1100px; margin: 28px auto 0; padding: 0 24px; display: flex; justify-content: flex-end; }
    .search-wrap { position: relative; }
    .search-wrap svg { position: absolute; top: 50%; transform: translateY(-50%); color: var(--search-ph); }
    [dir="ltr"] .search-wrap svg { left: 12px; }
    [dir="rtl"] .search-wrap svg { right: 12px; }
    .toolbar input {
      padding: 10px 14px 10px 38px; border: 1.5px solid var(--search-border);
      border-radius: 24px; font-size: .88rem; width: 260px; outline: none;
      background: var(--search-bg); color: var(--search-text);
      transition: border-color .2s; font-family: inherit;
    }
    [dir="rtl"] .toolbar input { padding: 10px 38px 10px 14px; }
    .toolbar input::placeholder { color: var(--search-ph); }
    .toolbar input:focus { border-color: var(--accent); }

    /* ── Sections ── */
    main { max-width: 1100px; margin: 24px auto 120px; padding: 0 24px; }
    .category-section { margin-bottom: 44px; scroll-margin-top: 90px; }
    .section-title {
      color: var(--section-title); font-size: 1.15rem; font-weight: 800; margin-bottom: 16px;
      padding-bottom: 12px; border-bottom: 2px solid var(--section-border);
      display: flex; align-items: center; gap: 10px; letter-spacing: .01em;
    }
    .section-title-img {
      width: 32px; height: 32px; border-radius: 50%; object-fit: cover;
      border: 2px solid var(--cat-border); flex-shrink: 0;
    }
    .items-inner-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; }

    /* ── Card ── */
    .card {
      background: #fff; border-radius: 16px; overflow: hidden;
      box-shadow: var(--card-shadow); border: 1px solid var(--card-border);
      cursor: pointer; transition: transform .22s, box-shadow .22s; position: relative;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .card:hover { transform: translateY(-5px); box-shadow: 0 14px 36px rgba(0,0,0,0.20); }
    .card.unavailable { opacity: .6; cursor: not-allowed; }
    .card-img-wrap { position: relative; overflow: hidden; }
    .card img { width: 100%; height: 170px; object-fit: cover; display: block; transition: transform .35s; }
    .card:hover .card-img-wrap img { transform: scale(1.06); }
    .unavailable-tag { position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: .95rem; }
    .badge { position: absolute; top: 10px; padding: 4px 10px; border-radius: 20px; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; background: var(--accent); color: #fff; }
    [dir="ltr"] .badge { left: 10px; }
    [dir="rtl"] .badge { right: 10px; }
    .badge-spicy      { background: #ff4d4d; }
    .badge-popular    { background: #f5a623; }
    .badge-new        { background: #00b894; }
    .badge-vegetarian { background: #27ae60; }
    .card-body { padding: 14px 16px 16px; }
    .card-body h3 { font-size: .98rem; font-weight: 700; margin-bottom: 5px; color: #1a1a2e; }
    .card-desc { color: #888; font-size: .8rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 10px; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; }
    .price { color: var(--accent); font-weight: 800; font-size: 1rem; }
    .add-btn {
      background: var(--accent); color: #fff; border: none; border-radius: 8px;
      padding: 6px 12px; font-size: .8rem; font-weight: 700; cursor: pointer;
      font-family: inherit; transition: opacity .15s, transform .1s; white-space: nowrap;
    }
    .add-btn:hover { opacity: .85; }
    .add-btn:active { transform: scale(.95); }

    /* ── Empty ── */
    .empty { text-align: center; padding: 80px 0; color: var(--empty-color); }
    .empty p { font-size: 1.05rem; margin-top: 12px; }

    /* ── Item Modal ── */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 200; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); }
    .overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 20px; max-width: 500px; width: 100%; overflow: hidden; animation: popIn .22s ease; position: relative; max-height: 90vh; overflow-y: auto; }
    @keyframes popIn { from { transform: scale(.92) translateY(20px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
    .modal-img-wrap { position: relative; background: #111; }
    .modal-img { width: 100%; max-height: 420px; object-fit: contain; display: block; }
    .modal-badge { position: absolute; bottom: 14px; padding: 5px 14px; border-radius: 20px; font-size: .8rem; font-weight: 700; text-transform: uppercase; background: var(--accent); color: #fff; }
    [dir="ltr"] .modal-badge { left: 14px; }
    [dir="rtl"] .modal-badge { right: 14px; }
    .modal-body { padding: 22px 24px 28px; }
    .modal-body h2 { font-size: 1.35rem; font-weight: 800; margin-bottom: 8px; color: #1a1a2e; }
    .modal-price { color: var(--accent); font-size: 1.25rem; font-weight: 800; margin-bottom: 12px; }
    .modal-desc { color: #666; line-height: 1.7; font-size: .92rem; margin-bottom: 20px; }
    .modal-cart-row { display: flex; align-items: center; gap: 12px; }
    .qty-ctrl { display: flex; align-items: center; border: 1.5px solid #e8e8e8; border-radius: 10px; overflow: hidden; }
    .qty-btn { background: #f5f5f5; border: none; width: 36px; height: 36px; font-size: 1.1rem; cursor: pointer; font-family: inherit; transition: background .15s; }
    .qty-btn:hover { background: #eaeaea; }
    .qty-val { width: 36px; text-align: center; font-weight: 700; font-size: .95rem; }
    .modal-add-btn {
      flex: 1; background: var(--accent); color: #fff; border: none; border-radius: 10px;
      padding: 12px 20px; font-size: .95rem; font-weight: 700; cursor: pointer;
      font-family: inherit; transition: opacity .15s; display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .modal-add-btn:hover { opacity: .88; }
    .close-btn {
      position: absolute; top: 12px; background: rgba(0,0,0,0.5); color: #fff; border: none;
      border-radius: 50%; width: 34px; height: 34px; font-size: 1rem; cursor: pointer;
      display: flex; align-items: center; justify-content: center; transition: background .2s; z-index: 1;
    }
    [dir="ltr"] .close-btn { right: 14px; }
    [dir="rtl"] .close-btn { left: 14px; }
    .close-btn:hover { background: rgba(0,0,0,0.75); }

    /* ── Floating Cart ── */
    .cart-fab {
      position: fixed; bottom: 28px; z-index: 150;
      background: var(--accent); color: #fff; border: none; border-radius: 50px;
      padding: 14px 22px; font-size: .95rem; font-weight: 700; cursor: pointer;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3); transition: transform .2s, opacity .2s;
      display: flex; align-items: center; gap: 10px; font-family: inherit;
    }
    [dir="ltr"] .cart-fab { right: 28px; }
    [dir="rtl"] .cart-fab { left: 28px; }
    .cart-fab:hover { transform: scale(1.05); }
    .cart-fab.hidden { opacity: 0; pointer-events: none; transform: scale(.8); }
    .cart-fab-count { background: #fff; color: var(--accent); border-radius: 50%; width: 22px; height: 22px; font-size: .75rem; font-weight: 900; display: flex; align-items: center; justify-content: center; }

    /* ── Cart Drawer ── */
    .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 300; display: none; backdrop-filter: blur(4px); }
    .cart-overlay.open { display: block; }
    .cart-drawer {
      position: fixed; top: 0; bottom: 0; width: min(420px, 100vw);
      background: #fff; z-index: 301; display: flex; flex-direction: column;
      box-shadow: -8px 0 40px rgba(0,0,0,0.2); transition: transform .3s cubic-bezier(.4,0,.2,1);
    }
    [dir="ltr"] .cart-drawer { right: 0; transform: translateX(100%); }
    [dir="rtl"] .cart-drawer { left: 0; transform: translateX(-100%); }
    .cart-drawer.open { transform: translateX(0); }
    .cart-header { padding: 20px 24px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: center; justify-content: space-between; }
    .cart-header h2 { font-size: 1.1rem; font-weight: 800; color: #1a1a2e; }
    .cart-close { background: none; border: none; font-size: 1.3rem; cursor: pointer; color: #888; transition: color .15s; }
    .cart-close:hover { color: #1a1a2e; }
    .cart-items { flex: 1; overflow-y: auto; padding: 16px 24px; }
    .cart-empty { text-align: center; padding: 60px 0; color: #bbb; }
    .cart-empty p { font-size: .95rem; margin-top: 12px; }
    .cart-item { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid #f5f5f5; }
    .cart-item:last-child { border-bottom: none; }
    .cart-item-img { width: 60px; height: 50px; border-radius: 10px; object-fit: cover; background: #f0f0f0; flex-shrink: 0; }
    .cart-item-info { flex: 1; min-width: 0; }
    .cart-item-name { font-weight: 700; font-size: .9rem; color: #1a1a2e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cart-item-price { color: var(--accent); font-weight: 700; font-size: .85rem; margin-top: 3px; }
    .cart-item-controls { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .cart-qty-btn { background: #f5f5f5; border: none; width: 28px; height: 28px; border-radius: 8px; font-size: .95rem; cursor: pointer; font-family: inherit; transition: background .15s; display: flex; align-items: center; justify-content: center; }
    .cart-qty-btn:hover { background: #eaeaea; }
    .cart-qty-val { font-weight: 700; font-size: .9rem; min-width: 20px; text-align: center; }
    .order-fields { padding: 16px 24px 0; display: flex; flex-direction: column; gap: 10px; border-top: 1px solid #f0f0f0; }
    .order-field-row { display: flex; gap: 10px; }
    .order-field {
      flex: 1; padding: 10px 12px; border: 1.5px solid #e8e8e8; border-radius: 10px;
      font-size: .85rem; font-family: inherit; outline: none; color: #1a1a2e; transition: border-color .2s;
    }
    .order-field:focus { border-color: var(--accent); }
    .order-field::placeholder { color: #bbb; }
    .cart-footer { padding: 16px 24px 24px; border-top: 1px solid #f0f0f0; }
    .cart-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .cart-total-label { font-size: .9rem; color: #888; font-weight: 600; }
    .cart-total-items { font-size: .85rem; color: #aaa; margin-top: 2px; }
    .cart-total-price { font-size: 1.2rem; font-weight: 800; color: #1a1a2e; }
    .whatsapp-order-btn {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      background: #25d366; color: #fff; border: none; border-radius: 14px;
      padding: 15px 20px; font-size: 1rem; font-weight: 700; cursor: pointer;
      width: 100%; font-family: inherit; transition: background .2s, transform .1s;
    }
    .whatsapp-order-btn:hover { background: #1da851; }
    .whatsapp-order-btn:active { transform: scale(.98); }

    /* ── Footer ── */
    footer { text-align: center; padding: 20px; color: var(--footer-color); font-size: .78rem; }

    /* ── Layout: List ── */
    [data-layout="list"] .items-inner-grid { display: flex; flex-direction: column; gap: 10px; }
    [data-layout="list"] .card { display: flex; flex-direction: row; border-radius: 14px; overflow: hidden; }
    [data-layout="list"] .card:hover { transform: translateY(-3px) translateX(2px); }
    [data-layout="list"] .card-img-wrap { width: 120px; min-width: 120px; flex-shrink: 0; }
    [data-layout="list"] .card-img-wrap img { width: 120px; height: 100%; min-height: 110px; object-fit: cover; border-radius: 0; }
    [data-layout="list"] .card-body { flex: 1; padding: 12px 14px; display: flex; flex-direction: column; justify-content: center; overflow: hidden; }
    [data-layout="list"] .card-body h3 { font-size: .9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
    [data-layout="list"] .card-desc { -webkit-line-clamp: 1; margin-bottom: 8px; }
    [data-layout="list"] .badge { top: 8px; font-size: .65rem; padding: 3px 8px; }

    /* ── Layout: Large ── */
    [data-layout="large"] .items-inner-grid { grid-template-columns: 1fr; gap: 20px; }
    [data-layout="large"] .card img { height: 240px; }
    [data-layout="large"] .card-body { padding: 18px 20px 20px; }
    [data-layout="large"] .card-body h3 { font-size: 1.1rem; margin-bottom: 8px; }
    [data-layout="large"] .card-desc { -webkit-line-clamp: 3; font-size: .85rem; }
    [data-layout="large"] .price { font-size: 1.1rem; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .modal { border-radius: 20px 20px 0 0; position: fixed; bottom: 0; left: 0; right: 0; max-width: 100%; max-height: 92vh; }
      .overlay { align-items: flex-end; padding: 0; }
      @keyframes popIn { from { transform: translateY(60px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    }
    @media (max-width: 600px) {
      .top-header { padding: 10px 14px; gap: 10px; }
      .nav-controls { padding: 4px 10px 0; }
      .nav-icon-btn { width: 30px; height: 30px; font-size: .9rem; }
      .cat-img-wrap { width: 36px; height: 36px; font-size: 1rem; }
      nav button { font-size: .72rem; padding: 8px 10px; gap: 4px; }
      main { padding: 0 10px; margin-bottom: 100px; }
      .items-inner-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      [data-layout="list"] .items-inner-grid,
      [data-layout="large"] .items-inner-grid { grid-template-columns: 1fr; }
      .card img { height: 140px; }
      [data-layout="large"] .card img { height: 180px; }
      [data-layout="list"] .card-img-wrap { width: 100px; min-width: 100px; }
      [data-layout="list"] .card-img-wrap img { width: 100px; }
      .card-body { padding: 10px 12px 12px; }
      .card-body h3 { font-size: .88rem; }
      .price { font-size: .9rem; }
      .toolbar { padding: 0 10px; margin-top: 16px; justify-content: stretch; }
      .search-wrap { width: 100%; }
      .toolbar input { width: 100%; }
      .cart-fab { bottom: 16px; padding: 11px 16px; font-size: .88rem; }
      [dir="ltr"] .cart-fab { right: 14px; }
      [dir="rtl"] .cart-fab { left: 14px; }
      .modal-img { max-height: 280px; }
      .order-field-row { flex-direction: column; }
      .section-title { font-size: 1rem; }
    }
    @media (max-width: 360px) {
      .items-inner-grid { grid-template-columns: 1fr; }
      .lang-switcher { gap: 2px; }
    }
    button, a { touch-action: manipulation; }

    /* ── Valet ── */
    .valet-btn {
      background: rgba(255,255,255,0.12); border: 1.5px solid rgba(255,255,255,0.2);
      color: #fff; border-radius: 50%; width: 42px; height: 42px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; cursor: pointer; transition: background .2s, transform .15s; flex-shrink: 0;
    }
    .valet-btn:hover { background: rgba(255,255,255,0.22); transform: scale(1.08); }
    .valet-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 400; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); }
    .valet-overlay.open { display: flex; }
    .valet-modal {
      background: #1a1a2e; border-radius: 20px; padding: 32px 28px;
      max-width: 380px; width: 100%; text-align: center;
      border: 1px solid rgba(255,255,255,0.1); animation: popIn .22s ease;
    }
    .valet-icon { font-size: 3rem; margin-bottom: 12px; }
    .valet-modal h2 { color: #fff; font-size: 1.25rem; font-weight: 800; margin-bottom: 6px; }
    .valet-modal p { color: rgba(255,255,255,0.55); font-size: .85rem; margin-bottom: 24px; line-height: 1.5; }
    .valet-input {
      width: 100%; padding: 13px 16px; border: 1.5px solid rgba(255,255,255,0.15);
      border-radius: 12px; background: rgba(255,255,255,0.08); color: #fff;
      font-size: 1rem; font-family: inherit; outline: none; margin-bottom: 12px; transition: border-color .2s;
    }
    .valet-input::placeholder { color: rgba(255,255,255,0.35); }
    .valet-input:focus { border-color: var(--accent); }
    .valet-send-btn {
      width: 100%; padding: 14px; background: var(--accent); color: #fff; border: none;
      border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer;
      font-family: inherit; display: flex; align-items: center; justify-content: center;
      gap: 10px; transition: opacity .2s; margin-top: 4px;
    }
    .valet-send-btn:hover { opacity: .88; }
    .valet-send-btn:disabled { opacity: .5; cursor: default; }
    .valet-cancel { margin-top: 12px; background: none; border: none; color: rgba(255,255,255,0.4); font-size: .85rem; cursor: pointer; font-family: inherit; }
    .valet-cancel:hover { color: rgba(255,255,255,0.7); }
    .valet-success { display: none; text-align: center; padding: 8px 0 4px; }
    .valet-success .success-icon { font-size: 3rem; margin-bottom: 10px; }
    .valet-success h3 { color: #fff; font-size: 1.1rem; margin-bottom: 6px; }
    .valet-success p { color: rgba(255,255,255,.5); font-size: .85rem; }

    /* ── Feedback ── */
    .fb-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 500; align-items: center; justify-content: center; padding: 16px; backdrop-filter: blur(4px); }
    .fb-overlay.open { display: flex; }
    .fb-modal {
      background: #fff; border-radius: 20px; padding: 26px 22px 20px;
      max-width: 420px; width: 100%; animation: popIn .22s ease;
      max-height: 92vh; overflow-y: auto; scrollbar-width: none;
    }
    .fb-modal::-webkit-scrollbar { display: none; }
    .fb-modal-head { text-align: center; margin-bottom: 20px; }
    .fb-icon { font-size: 2rem; margin-bottom: 6px; }
    .fb-modal h2 { font-size: 1.15rem; font-weight: 800; color: #1a1a2e; margin-bottom: 4px; }
    .fb-modal .fb-sub { color: #888; font-size: .82rem; }
    .fb-question { margin-bottom: 16px; }
    .fb-q-label { font-size: .82rem; font-weight: 700; color: #444; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    .fb-q-stars { display: flex; gap: 4px; }
    .fb-q-star { font-size: 1.7rem; cursor: pointer; color: #e0e0e0; transition: color .12s, transform .1s; line-height: 1; }
    .fb-q-star.sel { color: #f5a623; }
    .fb-q-star:hover { color: #f5a623; transform: scale(1.12); }
    .fb-divider { height: 1px; background: #f0f0f0; margin: 16px 0; }
    .fb-fields { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
    .fb-field {
      width: 100%; padding: 10px 13px; border: 1.5px solid #e8e8e8; border-radius: 10px;
      font-size: .87rem; font-family: inherit; color: #1a1a2e; outline: none; transition: border-color .2s; background: #fff;
    }
    .fb-field:focus { border-color: var(--accent); }
    .fb-field::placeholder { color: #bbb; }
    .fb-textarea {
      width: 100%; padding: 10px 13px; border: 1.5px solid #e8e8e8; border-radius: 10px;
      font-size: .87rem; font-family: inherit; resize: none; outline: none;
      color: #1a1a2e; transition: border-color .2s; margin-bottom: 12px; height: 70px; background: #fff;
    }
    .fb-textarea:focus { border-color: var(--accent); }
    .fb-textarea::placeholder { color: #bbb; }
    .fb-submit {
      width: 100%; padding: 13px; background: var(--accent); color: #fff; border: none;
      border-radius: 12px; font-size: .95rem; font-weight: 700; cursor: pointer;
      font-family: inherit; transition: opacity .2s;
    }
    .fb-submit:hover { opacity: .88; }
    .fb-submit:disabled { opacity: .5; cursor: default; }
    .fb-cancel { margin-top: 10px; background: none; border: none; color: #aaa; font-size: .82rem; cursor: pointer; font-family: inherit; display: block; width: 100%; text-align: center; }
    .fb-cancel:hover { color: #555; }
    .fb-success { display: none; text-align: center; padding: 20px 0; }
    .fb-success .fb-ok { font-size: 3rem; margin-bottom: 12px; }
    .fb-success h3 { font-size: 1.1rem; font-weight: 800; color: #1a1a2e; margin-bottom: 6px; }
    .fb-success p { color: #888; font-size: .85rem; }

    /* Splash feedback pill */
    .splash-feedback-btn {
      display: flex; align-items: center; gap: 7px;
      background: #fff; color: var(--accent); border: 2px solid var(--accent);
      border-radius: 99px; padding: 9px 16px; font-size: .82rem;
      font-weight: 700; cursor: pointer; font-family: var(--font);
      transition: background .15s, color .15s;
    }
    .splash-feedback-btn:hover { background: var(--accent); color: #fff; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)} }

    /* ── Splash ── */
    .splash {
      position: fixed; inset: 0; z-index: 2000;
      background: #fff; display: flex; flex-direction: column;
      transition: opacity .45s ease, transform .45s ease;
    }
    .splash.out { opacity: 0; transform: scale(1.03); pointer-events: none; }
    .splash-top {
      display: flex; justify-content: space-between; align-items: flex-start;
      padding: 20px 20px 0;
    }
    .splash-pill {
      display: flex; align-items: center; gap: 7px;
      background: var(--accent); color: #fff; border: none;
      border-radius: 99px; padding: 10px 18px; font-size: .85rem;
      font-weight: 700; cursor: pointer; font-family: var(--font);
      box-shadow: 0 4px 14px rgba(0,0,0,0.15); transition: opacity .15s;
    }
    .splash-pill:hover { opacity: .88; }
    .splash-center {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; padding: 0 32px;
      gap: 36px;
    }
    .splash-logo-wrap {
      width: 200px; height: 200px; border-radius: 50%; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      font-size: 5rem;
    }
    .splash-logo-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .splash-langs { width: 100%; max-width: 320px; display: flex; flex-direction: column; gap: 12px; }
    .splash-lang-btn {
      width: 100%; padding: 16px; background: var(--accent); color: #fff;
      border: none; border-radius: 14px; font-size: 1.05rem; font-weight: 700;
      cursor: pointer; font-family: var(--font); transition: opacity .15s, transform .1s;
      letter-spacing: .02em;
    }
    .splash-lang-btn:hover { opacity: .88; }
    .splash-lang-btn:active { transform: scale(.97); }
    .splash-lang-row { display: flex; gap: 12px; }
    .splash-lang-row .splash-lang-btn { flex: 1; }
    .splash-bottom {
      padding: 0 32px 40px; text-align: center;
    }
    .splash-rest-name {
      font-size: 2.2rem; font-weight: 900; color: var(--accent);
      letter-spacing: .04em; text-transform: uppercase; line-height: 1.1;
      font-family: var(--font);
    }
    .splash-rest-desc {
      font-size: .85rem; color: #aaa; margin-top: 4px; letter-spacing: .06em; text-transform: uppercase;
    }
    @media (max-width: 400px) {
      .splash-logo-wrap { width: 160px; height: 160px; }
      .splash-rest-name { font-size: 1.7rem; }
    }
  </style>
</head>
<body data-layout="<%= _layout %>">

<!-- Splash / Language Selection -->
<div class="splash" id="splash">
  <div class="splash-top">
    <% if (tenant.valet_enabled) { %>
    <button class="splash-pill" onclick="splashValet()">🚗 Valet</button>
    <% } else { %>
    <div></div>
    <% } %>
    <button class="splash-feedback-btn" onclick="splashFeedback()">💬 Feedback</button>
  </div>

  <div class="splash-center">
    <div class="splash-logo-wrap">
      <% if (tenant.logo_url) { %>
        <img src="<%= tenant.logo_url %>" alt="<%= tenant.name %>" />
      <% } else { %>
        🍽️
      <% } %>
    </div>

    <div class="splash-langs">
      <button class="splash-lang-btn" onclick="selectLang('en')">English</button>
      <div class="splash-lang-row">
        <button class="splash-lang-btn" onclick="selectLang('ku')">كوردى</button>
        <button class="splash-lang-btn" onclick="selectLang('ar')">العربية</button>
      </div>
    </div>
  </div>

  <div class="splash-bottom">
    <div class="splash-rest-name"><%= tenant.name %></div>
    <% if (tenant.description) { %><div class="splash-rest-desc"><%= tenant.description %></div><% } %>
  </div>
</div>

<!-- Background -->
<div class="page-bg">
  <% if (tenant.bg_video) { %>
    <video class="page-bg-video" autoplay muted loop playsinline><source src="<%= tenant.bg_video %>" /></video>
  <% } else if (tenant.cover_image) { %>
    <img class="page-bg-img" src="<%= tenant.cover_image %>" alt="" />
  <% } %>
  <div class="page-bg-overlay"></div>
</div>

<div class="page-content">

  <div class="content-sheet">

  <!-- Category Nav (sticky) -->
  <div class="sticky-wrap">
    <div class="nav-controls">
      <% if (tenant.valet_enabled) { %>
      <button class="nav-icon-btn" onclick="openValet()" title="Valet">🚗</button>
      <% } %>
      <button class="nav-icon-btn" onclick="showSplash()" title="Language">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </button>
      <button class="nav-icon-btn" onclick="openFeedback()" title="Feedback">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </button>
    </div>
    <nav id="categoryNav">
      <button class="active" data-id="all">
        <div class="cat-img-wrap">🍴</div>
        <span class="cat-label"></span>
      </button>
      <% categories.forEach(cat => { %>
        <button data-id="<%= cat.id %>">
          <div class="cat-img-wrap">
            <% if (cat.image_url) { %><img src="<%= cat.image_url %>" alt="<%= cat.name %>" /><% } else { %>🍽️<% } %>
          </div>
          <span class="cat-label"><%= cat.name %></span>
        </button>
      <% }) %>
    </nav>
    <!-- Closed Banner sits below categories, still inside sticky -->
    <div id="closedBanner" style="display:none;background:rgba(233,69,96,0.92);color:#fff;text-align:center;padding:10px 20px;font-weight:600;font-size:.88rem;backdrop-filter:blur(8px);">
      🕐 <span id="closedBannerText"></span>
    </div>
  </div>

  <!-- Search -->
  <div class="toolbar">
    <div class="search-wrap">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="searchInput" />
    </div>
  </div>

  <!-- Grid -->
  <main id="itemsGrid"></main>

  <!-- Item Modal -->
  <div class="overlay" id="overlay">
    <div class="modal">
      <button class="close-btn" id="closeModal">✕</button>
      <div class="modal-img-wrap">
        <img class="modal-img" id="modalImg" src="" alt="" />
        <span class="modal-badge" id="modalBadge" style="display:none"></span>
      </div>
      <div class="modal-body">
        <h2 id="modalName"></h2>
        <div class="modal-price" id="modalPrice"></div>
        <p class="modal-desc" id="modalDesc"></p>
        <% if (tenant.cart_enabled !== false) { %>
        <div class="modal-cart-row">
          <div class="qty-ctrl">
            <button class="qty-btn" id="modalQtyMinus">−</button>
            <span class="qty-val" id="modalQtyVal">1</span>
            <button class="qty-btn" id="modalQtyPlus">+</button>
          </div>
          <button class="modal-add-btn" id="modalAddBtn">
            🛒 <span id="modalAddBtnText"></span>
          </button>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <footer id="footer"></footer>
  </div><!-- /content-sheet -->
</div>

<% if (tenant.valet_enabled) { %>
<!-- Valet Modal -->
<div class="valet-overlay" id="valetOverlay">
  <div class="valet-modal">
    <!-- Form state -->
    <div id="valetForm">
      <div class="valet-icon">🚗</div>
      <h2 id="valetTitle">Valet Service</h2>
      <p id="valetDesc">Enter your ticket number and we'll bring your car right away.</p>
      <input class="valet-input" type="text" id="valetTicket" placeholder="Ticket number" inputmode="numeric" />
      <input class="valet-input" type="text" id="valetName" placeholder="Your name (optional)" />
      <button class="valet-send-btn" id="valetSendBtn" onclick="sendValetRequest()">
        <span>🚗</span>
        <span id="valetBtnText">Request My Car</span>
      </button>
      <button class="valet-cancel" onclick="closeValet()" id="valetCancel">Cancel</button>
    </div>
    <!-- Success state -->
    <div class="valet-success" id="valetSuccess">
      <div class="success-icon">✅</div>
      <h3 id="valetSuccessTitle">Request Sent!</h3>
      <p id="valetSuccessDesc">Your car is on the way. Please wait near the entrance.</p>
    </div>
  </div>
</div>
<% } %>

<!-- Feedback Modal -->
<div class="fb-overlay" id="fbOverlay" onclick="fbOverlayClick(event)">
  <div class="fb-modal" id="fbModal">
    <div id="fbForm">
      <div class="fb-modal-head">
        <div class="fb-icon">💬</div>
        <h2 id="fbTitle">Share Your Feedback</h2>
        <p class="fb-sub" id="fbSub">Rate your experience today</p>
      </div>

      <div class="fb-question" id="fbQ1">
        <div class="fb-q-label">🍽️ <span id="fbL1">Food Quality</span></div>
        <div class="fb-q-stars">
          <span class="fb-q-star" data-q="1" data-v="1" onclick="selectStar(1,1)">★</span>
          <span class="fb-q-star" data-q="1" data-v="2" onclick="selectStar(1,2)">★</span>
          <span class="fb-q-star" data-q="1" data-v="3" onclick="selectStar(1,3)">★</span>
          <span class="fb-q-star" data-q="1" data-v="4" onclick="selectStar(1,4)">★</span>
          <span class="fb-q-star" data-q="1" data-v="5" onclick="selectStar(1,5)">★</span>
        </div>
      </div>

      <div class="fb-question" id="fbQ2">
        <div class="fb-q-label">🙋 <span id="fbL2">Service</span></div>
        <div class="fb-q-stars">
          <span class="fb-q-star" data-q="2" data-v="1" onclick="selectStar(2,1)">★</span>
          <span class="fb-q-star" data-q="2" data-v="2" onclick="selectStar(2,2)">★</span>
          <span class="fb-q-star" data-q="2" data-v="3" onclick="selectStar(2,3)">★</span>
          <span class="fb-q-star" data-q="2" data-v="4" onclick="selectStar(2,4)">★</span>
          <span class="fb-q-star" data-q="2" data-v="5" onclick="selectStar(2,5)">★</span>
        </div>
      </div>

      <div class="fb-question" id="fbQ3">
        <div class="fb-q-label">🏡 <span id="fbL3">Atmosphere</span></div>
        <div class="fb-q-stars">
          <span class="fb-q-star" data-q="3" data-v="1" onclick="selectStar(3,1)">★</span>
          <span class="fb-q-star" data-q="3" data-v="2" onclick="selectStar(3,2)">★</span>
          <span class="fb-q-star" data-q="3" data-v="3" onclick="selectStar(3,3)">★</span>
          <span class="fb-q-star" data-q="3" data-v="4" onclick="selectStar(3,4)">★</span>
          <span class="fb-q-star" data-q="3" data-v="5" onclick="selectStar(3,5)">★</span>
        </div>
      </div>

      <div class="fb-question" id="fbQ4">
        <div class="fb-q-label">💰 <span id="fbL4">Value for Money</span></div>
        <div class="fb-q-stars">
          <span class="fb-q-star" data-q="4" data-v="1" onclick="selectStar(4,1)">★</span>
          <span class="fb-q-star" data-q="4" data-v="2" onclick="selectStar(4,2)">★</span>
          <span class="fb-q-star" data-q="4" data-v="3" onclick="selectStar(4,3)">★</span>
          <span class="fb-q-star" data-q="4" data-v="4" onclick="selectStar(4,4)">★</span>
          <span class="fb-q-star" data-q="4" data-v="5" onclick="selectStar(4,5)">★</span>
        </div>
      </div>

      <div class="fb-question" id="fbQ5">
        <div class="fb-q-label">⭐ <span id="fbL5">Overall Experience</span></div>
        <div class="fb-q-stars">
          <span class="fb-q-star" data-q="5" data-v="1" onclick="selectStar(5,1)">★</span>
          <span class="fb-q-star" data-q="5" data-v="2" onclick="selectStar(5,2)">★</span>
          <span class="fb-q-star" data-q="5" data-v="3" onclick="selectStar(5,3)">★</span>
          <span class="fb-q-star" data-q="5" data-v="4" onclick="selectStar(5,4)">★</span>
          <span class="fb-q-star" data-q="5" data-v="5" onclick="selectStar(5,5)">★</span>
        </div>
      </div>

      <div class="fb-divider"></div>

      <div class="fb-fields">
        <input class="fb-field" type="text" id="fbName" placeholder="Your name (optional)" />
        <input class="fb-field" type="tel" id="fbMobile" placeholder="Mobile number (optional)" />
        <input class="fb-field" type="text" id="fbTable" placeholder="Table number (optional)" />
      </div>

      <textarea class="fb-textarea" id="fbComment" placeholder="Any other comments... (optional)"></textarea>

      <button class="fb-submit" id="fbSubmitBtn" onclick="submitFeedback()">Send Feedback</button>
      <button class="fb-cancel" onclick="closeFeedback()">Cancel</button>
    </div>
    <!-- Success state -->
    <div class="fb-success" id="fbSuccess">
      <div class="fb-ok">🎉</div>
      <h3 id="fbSuccessTitle">Thank you!</h3>
      <p id="fbSuccessDesc">Your feedback means a lot to us.</p>
    </div>
  </div>
</div>

<% if (tenant.cart_enabled !== false) { %>
<!-- Floating Cart Button -->
<button class="cart-fab hidden" id="cartFab" onclick="openCart()">
  🛒 <span id="cartFabLabel"></span>
  <span class="cart-fab-count" id="cartFabCount">0</span>
</button>

<!-- Cart Drawer -->
<div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <h2 id="cartTitle"></h2>
    <button class="cart-close" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>

  <!-- Customer name + table number -->
  <div class="order-fields" id="orderFields" style="display:none">
    <div class="order-field-row">
      <input class="order-field" type="text" id="orderName" />
      <input class="order-field" type="text" id="orderTable" />
    </div>
  </div>

  <div class="cart-footer">
    <div class="cart-total">
      <div>
        <div class="cart-total-label" id="cartTotalLabel"></div>
        <div class="cart-total-items" id="cartTotalItems"></div>
      </div>
    </div>
    <% if (tenant.whatsapp) { %>
    <button class="whatsapp-order-btn" id="placeOrderBtn" onclick="placeOrderWhatsApp()">
      <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.122.557 4.112 1.524 5.842L0 24l6.302-1.504A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.001-1.366l-.357-.214-3.74.892.946-3.617-.233-.373A9.789 9.789 0 0 1 2.182 12C2.182 6.579 6.579 2.182 12 2.182S21.818 6.579 21.818 12 17.421 21.818 12 21.818z"/></svg>
      <span id="placeOrderBtnText"></span>
    </button>
    <% } %>
  </div>
</div>
<% } %>

<script>
  const items      = <%- JSON.stringify(items) %>;
  const categories = <%- JSON.stringify(categories) %>;
  const WHATSAPP   = '<%= tenant.whatsapp || "" %>';
  const REST_NAME  = '<%= tenant.name %>';
  const CART_ENABLED   = <%= tenant.cart_enabled !== false ? 'true' : 'false' %>;
  const TENANT_ID      = <%= tenant.id %>;
  const VALET_ENABLED  = <%= tenant.valet_enabled ? 'true' : 'false' %>;
  const VALET_WA       = <%- JSON.stringify(tenant.valet_whatsapp || tenant.whatsapp || '') %>;
  const FB_Q           = <%- JSON.stringify(_fbQ) %>;
  const CURRENCY       = <%- JSON.stringify(tenant.currency || '$') %>;
  const OPEN_TIME      = <%- JSON.stringify(tenant.open_time  ? String(tenant.open_time).substring(0,5)  : '') %>;
  const CLOSE_TIME     = <%- JSON.stringify(tenant.close_time ? String(tenant.close_time).substring(0,5) : '') %>;
  const IS_ALWAYS_OPEN = <%= tenant.is_always_open !== false ? 'true' : 'false' %>;

  const LANG = {
    en: {
      dir: 'ltr', lang: 'en',
      all: 'All', search: 'Search items...', notFound: 'No items found.',
      unavailable: 'Unavailable', footer: 'Powered by MenuApp',
      addToCart: 'Add to Cart', cart: 'Your Cart', emptyCart: 'Your cart is empty',
      totalItems: 'items', placeOrder: 'Place Order via WhatsApp',
      cartBtn: 'Cart', yourName: 'Your name', tableNo: 'Table no.',
      closed: "We're currently closed", opensAt: 'Opens at', featured: 'Featured',
      valetTitle: 'Valet Service', valetDesc: "Enter your ticket number and we'll bring your car right away.", valetTicket: 'Ticket number', valetName: 'Your name (optional)', valetBtn: 'Request My Car', valetCancel: 'Cancel', valetSuccessTitle: 'Request Sent!', valetSuccessDesc: 'Your car is on the way. Please wait near the entrance.',
      fbTitle: 'Share Your Feedback', fbSub: 'Rate your experience today',
      fbQ1: '🍽️ Food Quality', fbQ2: '🙋 Service', fbQ3: '🏡 Atmosphere', fbQ4: '💰 Value for Money', fbQ5: '⭐ Overall Experience',
      fbName: 'Your name (optional)', fbMobile: 'Mobile number (optional)', fbTable: 'Table number (optional)', fbComment: 'Any other comments... (optional)', fbSubmit: 'Send Feedback', fbCancel: 'Cancel', fbSuccessTitle: 'Thank you!', fbSuccessDesc: 'Your feedback means a lot to us.',
      badges: { spicy:'🌶 Spicy', popular:'⭐ Popular', new:'🆕 New', vegetarian:'🌱 Veg' }
    },
    ar: {
      dir: 'rtl', lang: 'ar',
      all: 'الكل', search: 'ابحث عن الأصناف...', notFound: 'لا توجد أصناف.',
      unavailable: 'غير متوفر', footer: 'مدعوم من MenuApp',
      addToCart: 'أضف إلى السلة', cart: 'سلة الطلبات', emptyCart: 'سلتك فارغة',
      totalItems: 'عناصر', placeOrder: 'اطلب عبر واتساب',
      cartBtn: 'السلة', yourName: 'اسمك', tableNo: 'رقم الطاولة',
      closed: 'نحن مغلقون حاليًا', opensAt: 'يفتح الساعة', featured: 'المميزة',
      valetTitle: 'خدمة الفاليه', valetDesc: 'أدخل رقم التذكرة وسنحضر سيارتك فوراً.', valetTicket: 'رقم التذكرة', valetName: 'اسمك (اختياري)', valetBtn: 'اطلب سيارتي', valetCancel: 'إلغاء', valetSuccessTitle: 'تم الإرسال!', valetSuccessDesc: 'سيارتك في الطريق. يرجى الانتظار عند المدخل.',
      fbTitle: 'شاركنا رأيك', fbSub: 'قيّم تجربتك اليوم',
      fbQ1: '🍽️ جودة الطعام', fbQ2: '🙋 الخدمة', fbQ3: '🏡 الأجواء', fbQ4: '💰 القيمة مقابل السعر', fbQ5: '⭐ التجربة العامة',
      fbName: 'اسمك (اختياري)', fbMobile: 'رقم الهاتف (اختياري)', fbTable: 'رقم الطاولة (اختياري)', fbComment: 'أي تعليقات أخرى... (اختياري)', fbSubmit: 'إرسال الرأي', fbCancel: 'إلغاء', fbSuccessTitle: 'شكراً لك!', fbSuccessDesc: 'رأيك يهمنا كثيراً.',
      badges: { spicy:'🌶 حار', popular:'⭐ الأكثر طلباً', new:'🆕 جديد', vegetarian:'🌱 نباتي' }
    },
    ku: {
      dir: 'rtl', lang: 'ku',
      all: 'هەمووی', search: 'بگەڕێ بۆ بەرهەم...', notFound: 'هیچ بەرهەمێک نەدۆزرایەوە.',
      unavailable: 'بەردەست نییە', footer: 'دروستکراوە لەلایەن MenuApp',
      addToCart: 'زیادبکە بۆ سەبەتە', cart: 'سەبەتەی داواکاری', emptyCart: 'سەبەتەکەت بەتاڵە',
      totalItems: 'کاڵا', placeOrder: 'داواکاری لە واتساپ',
      cartBtn: 'سەبەتە', yourName: 'ناوت', tableNo: 'ژمارەی مێز',
      closed: 'ئێستا داخراوین', opensAt: 'دەکرێتەوە لە', featured: 'تایبەتمەندەکان',
      valetTitle: 'خزمەتگوزاری ڤالێت', valetDesc: 'ژمارەی تیکێتەکەت بنووسە، ئەمەندا ئۆتۆمبێلەکەت دەهێنینەوە.', valetTicket: 'ژمارەی تیکێت', valetName: 'ناوت (ئارەزوومەندانە)', valetBtn: 'داوای ئۆتۆمبێلەکەم بکە', valetCancel: 'پاشگەزبوونەوە', valetSuccessTitle: 'داواکاری نێردرا!', valetSuccessDesc: 'ئۆتۆمبێلەکەت لە ڕێگایە. تکایە لە نزیکی دەروازەکە چاوەڕێ بە.',
      fbTitle: 'ڕای خۆت بڵێ', fbSub: 'ئەمڕۆی تجربەکەت هەڵسەنگاندن بکە',
      fbQ1: '🍽️ چێژی خواردن', fbQ2: '🙋 خزمەتگوزاری', fbQ3: '🏡 ژینگەکە', fbQ4: '💰 کار لە بەرانبەر نرخ', fbQ5: '⭐ کۆی ئەزموون',
      fbName: 'ناوت (ئارەزوومەندانە)', fbMobile: 'ژمارەی مۆبایل (ئارەزوومەندانە)', fbTable: 'ژمارەی مێز (ئارەزوومەندانە)', fbComment: 'هەر تێبینییەکی تر... (ئارەزوومەندانە)', fbSubmit: 'ڕای بنێرە', fbCancel: 'پاشگەزبوونەوە', fbSuccessTitle: 'سوپاست!', fbSuccessDesc: 'ڕایەکەت زۆر گرنگە بۆمان.',
      badges: { spicy:'🌶 تیژ', popular:'⭐ بەناوبانگ', new:'🆕 نوێ', vegetarian:'🌱 ڕووەکی' }
    }
  };

  const BADGE_CLASS = { spicy:'badge-spicy', popular:'badge-popular', new:'badge-new', vegetarian:'badge-vegetarian' };

  let currentLang    = localStorage.getItem('lang') || 'en';
  let searchQuery    = '';
  let activeCategory = 'all';
  let modalItem      = null;
  let modalQty       = 1;

  // ── Cart ──────────────────────────────────────────
  let cart = [];
  function cartTotalQty() { return cart.reduce((s, e) => s + e.qty, 0); }

  function addToCart(item, qty) {
    const existing = cart.find(e => e.item.id === item.id);
    if (existing) existing.qty += qty;
    else cart.push({ item, qty });
    updateCartFab();
  }

  function changeQty(itemId, delta) {
    const entry = cart.find(e => e.item.id === itemId);
    if (!entry) return;
    entry.qty += delta;
    if (entry.qty <= 0) cart = cart.filter(e => e.item.id !== itemId);
    updateCartFab();
    renderCartItems();
  }

  function updateCartFab() {
    const total = cartTotalQty();
    const fab   = document.getElementById('cartFab');
    document.getElementById('cartFabCount').textContent = total;
    fab.classList.toggle('hidden', total === 0);
    if (!document.getElementById('cartItems').querySelector('.cart-empty')) renderCartItems();
  }

  // ── Cart Drawer ───────────────────────────────────
  function openCart() {
    document.getElementById('cartOverlay').classList.add('open');
    document.getElementById('cartDrawer').classList.add('open');
    document.body.style.overflow = 'hidden';
    renderCartItems();
  }
  function closeCart() {
    document.getElementById('cartOverlay').classList.remove('open');
    document.getElementById('cartDrawer').classList.remove('open');
    document.body.style.overflow = '';
  }

  function renderCartItems() {
    const L  = LANG[currentLang];
    const el = document.getElementById('cartItems');
    document.getElementById('cartTitle').textContent      = L.cart;
    document.getElementById('cartTotalLabel').textContent = L.totalItems;
    document.getElementById('cartTotalItems').textContent = cartTotalQty() + ' ' + L.totalItems;
    if (document.getElementById('placeOrderBtnText'))
      document.getElementById('placeOrderBtnText').textContent = L.placeOrder;

    const fields = document.getElementById('orderFields');
    if (cart.length === 0) {
      el.innerHTML = `<div class="cart-empty">
        <svg width="56" height="56" fill="none" stroke="#ccc" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.4 5h12.8"/></svg>
        <p>${L.emptyCart}</p>
      </div>`;
      if (fields) fields.style.display = 'none';
      return;
    }

    if (fields) fields.style.display = '';
    if (document.getElementById('orderName')) document.getElementById('orderName').placeholder = L.yourName;
    if (document.getElementById('orderTable')) document.getElementById('orderTable').placeholder = L.tableNo;

    el.innerHTML = cart.map(({ item, qty }) => {
      const name = getLocalized(item, 'name', currentLang);
      return `<div class="cart-item">
        <img class="cart-item-img" src="${item.image_url || 'https://placehold.co/60x50?text=?'}" alt="${name}" />
        <div class="cart-item-info">
          <div class="cart-item-name">${name}</div>
          <div class="cart-item-price">${item.price}</div>
        </div>
        <div class="cart-item-controls">
          <button class="cart-qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
          <span class="cart-qty-val">${qty}</span>
          <button class="cart-qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
        </div>
      </div>`;
    }).join('');
  }

  // ── WhatsApp Order ────────────────────────────────
  function placeOrderWhatsApp() {
    if (cart.length === 0 || !WHATSAPP) return;
    const L     = LANG[currentLang];
    const name  = (document.getElementById('orderName')  || {}).value || '';
    const table = (document.getElementById('orderTable') || {}).value || '';
    let msg = `🍽️ *${REST_NAME}*\n`;
    if (name.trim())  msg += `👤 ${name.trim()}\n`;
    if (table.trim()) msg += `🪑 ${L.tableNo}: ${table.trim()}\n`;
    msg += `\n${L.cart}:\n\n`;
    cart.forEach(({ item, qty }) => {
      msg += `• ${getLocalized(item, 'name', currentLang)} x${qty} — ${CURRENCY}${item.price}\n`;
    });
    msg += `\n📦 ${L.totalItems}: ${cartTotalQty()}`;

    // Log order (fire and forget)
    fetch('/api/order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tenant_id: TENANT_ID,
        customer_name: name.trim() || null,
        table_no: table.trim() || null,
        items: cart.map(({ item, qty }) => ({ name: item.name, qty, price: item.price })),
        item_count: cartTotalQty()
      })
    }).catch(() => {});

    window.open(`https://wa.me/${WHATSAPP.replace(/\D/g,'')}?text=${encodeURIComponent(msg)}`, '_blank');
  }

  // ── Opening Hours ─────────────────────────────────
  function isOpen() {
    if (IS_ALWAYS_OPEN || !OPEN_TIME || !CLOSE_TIME) return true;
    const now  = new Date();
    const mins = now.getHours() * 60 + now.getMinutes();
    const [oh, om] = OPEN_TIME.split(':').map(Number);
    const [ch, cm] = CLOSE_TIME.split(':').map(Number);
    const openMins  = oh * 60 + om;
    const closeMins = ch * 60 + cm;
    return closeMins > openMins
      ? mins >= openMins && mins < closeMins
      : mins >= openMins || mins < closeMins;
  }

  function updateClosedBanner(L) {
    const banner = document.getElementById('closedBanner');
    const text   = document.getElementById('closedBannerText');
    if (!isOpen()) {
      text.textContent = OPEN_TIME ? `${L.closed} · ${L.opensAt} ${OPEN_TIME}` : L.closed;
      banner.style.display = '';
    } else {
      banner.style.display = 'none';
    }
  }

  // ── Language ──────────────────────────────────────
  function setLang(lang) {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    const L = LANG[lang];
    document.documentElement.dir  = L.dir;
    document.documentElement.lang = L.lang;
    document.querySelectorAll('.lang-btn').forEach((btn, i) => {
      btn.classList.toggle('active', ['en','ar','ku'][i] === lang);
    });
    document.getElementById('searchInput').placeholder = L.search;
    document.getElementById('footer').textContent      = L.footer;
    if (CART_ENABLED) {
      document.getElementById('cartFabLabel').textContent = L.cartBtn;
      if (document.getElementById('modalAddBtnText'))
        document.getElementById('modalAddBtnText').textContent = L.addToCart;
    }
    updateClosedBanner(L);
    if (VALET_ENABLED) {
      document.getElementById('valetTitle').textContent        = L.valetTitle;
      document.getElementById('valetDesc').textContent         = L.valetDesc;
      document.getElementById('valetTicket').placeholder       = L.valetTicket;
      document.getElementById('valetName').placeholder         = L.valetName;
      document.getElementById('valetBtnText').textContent      = L.valetBtn;
      document.getElementById('valetCancel').textContent       = L.valetCancel;
      document.getElementById('valetSuccessTitle').textContent = L.valetSuccessTitle;
      document.getElementById('valetSuccessDesc').textContent  = L.valetSuccessDesc;
    }
    // Feedback modal labels
    document.getElementById('fbTitle').textContent        = L.fbTitle;
    document.getElementById('fbSub').textContent          = L.fbSub;
    const _qs = FB_Q[lang] || FB_Q.en;
    document.getElementById('fbL1').textContent           = _qs[0];
    document.getElementById('fbL2').textContent           = _qs[1];
    document.getElementById('fbL3').textContent           = _qs[2];
    document.getElementById('fbL4').textContent           = _qs[3];
    document.getElementById('fbL5').textContent           = _qs[4];
    document.getElementById('fbName').placeholder         = L.fbName;
    document.getElementById('fbMobile').placeholder       = L.fbMobile;
    document.getElementById('fbTable').placeholder        = L.fbTable;
    document.getElementById('fbComment').placeholder      = L.fbComment;
    document.getElementById('fbSubmitBtn').textContent    = L.fbSubmit;
    document.getElementById('fbSuccessTitle').textContent = L.fbSuccessTitle;
    document.getElementById('fbSuccessDesc').textContent  = L.fbSuccessDesc;
    document.querySelectorAll('.fb-cancel').forEach(b => b.textContent = L.fbCancel);
    updateCategoryNav();
    renderGrid();
    if (CART_ENABLED && document.getElementById('cartDrawer').classList.contains('open')) renderCartItems();
  }

  function getLocalized(item, field, lang) {
    if (lang === 'ar' && item[field + '_ar']) return item[field + '_ar'];
    if (lang === 'ku' && item[field + '_ku']) return item[field + '_ku'];
    return item[field] || '';
  }

  function updateCategoryNav() {
    const L = LANG[currentLang];
    document.querySelector('[data-id="all"] .cat-label').textContent = L.all;
    categories.forEach(cat => {
      const btn = document.querySelector(`[data-id="${cat.id}"]`);
      if (btn) { const lbl = btn.querySelector('.cat-label'); if (lbl) lbl.textContent = getLocalized(cat, 'name', currentLang); }
    });
  }

  // ── Category Nav ──────────────────────────────────
  document.getElementById('categoryNav').querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.id;
      setActiveNav(activeCategory);
      renderGrid();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  function setActiveNav(catId) {
    document.querySelectorAll('#categoryNav button').forEach(b => b.classList.remove('active'));
    const target = document.querySelector(`#categoryNav [data-id="${catId}"]`);
    if (target) {
      target.classList.add('active');
      target.scrollIntoView({ block: 'nearest', inline: 'center' });
    }
  }

  // ── Search ────────────────────────────────────────
  let searchTimer;
  document.getElementById('searchInput').addEventListener('input', e => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { searchQuery = e.target.value.toLowerCase(); renderGrid(); }, 200);
  });

  // ── Render Grid ───────────────────────────────────
  function renderGrid() {
    const L    = LANG[currentLang];
    const grid = document.getElementById('itemsGrid');
    grid.innerHTML = '';

    // Determine which items to show
    const filtered = items.filter(item => {
      const matchCat = activeCategory === 'all' || Number(item.category_id) === Number(activeCategory);
      if (!matchCat) return false;
      if (!searchQuery) return true;
      return (item.name || '').toLowerCase().includes(searchQuery) ||
             (item.description || '').toLowerCase().includes(searchQuery) ||
             (item.description_ar || '').toLowerCase().includes(searchQuery) ||
             (item.description_ku || '').toLowerCase().includes(searchQuery) ||
             (item.name_ar || '').toLowerCase().includes(searchQuery) ||
             (item.name_ku || '').toLowerCase().includes(searchQuery);
    });

    if (filtered.length === 0) {
      grid.innerHTML = `<div class="empty"><svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><p>${L.notFound}</p></div>`;
      return;
    }

    if (activeCategory === 'all') {
      // Featured section
      const featured = filtered.filter(item => item.is_featured);
      if (featured.length > 0 && !searchQuery) {
        const sec = document.createElement('section');
        sec.className = 'category-section';
        const ttl = document.createElement('h2');
        ttl.className = 'section-title';
        ttl.innerHTML = `<span style="font-size:1.2rem">⭐</span> ${L.featured}`;
        sec.appendChild(ttl);
        const fg = document.createElement('div');
        fg.className = 'items-inner-grid';
        featured.forEach((item, i) => { const c = buildCard(item, L); c.style.animationDelay = (i*40)+'ms'; fg.appendChild(c); });
        sec.appendChild(fg);
        grid.appendChild(sec);
      }

      // Group by category with section headers
      categories.forEach(cat => {
        const catItems = filtered.filter(item => Number(item.category_id) === Number(cat.id));
        if (catItems.length === 0) return;

        const section = document.createElement('section');
        section.className = 'category-section';

        const title = document.createElement('h2');
        title.className = 'section-title';
        if (cat.image_url) {
          const img = document.createElement('img');
          img.src = cat.image_url; img.alt = ''; img.className = 'section-title-img';
          title.appendChild(img);
        }
        title.appendChild(document.createTextNode(getLocalized(cat, 'name', currentLang)));
        section.appendChild(title);

        const innerGrid = document.createElement('div');
        innerGrid.className = 'items-inner-grid';
        catItems.forEach((item, i) => {
          const card = buildCard(item, L);
          card.style.animationDelay = (i * 40) + 'ms';
          innerGrid.appendChild(card);
        });
        section.appendChild(innerGrid);
        grid.appendChild(section);
      });

      // Uncategorized
      const uncat = filtered.filter(item => !item.category_id);
      if (uncat.length > 0) {
        const innerGrid = document.createElement('div');
        innerGrid.className = 'items-inner-grid';
        uncat.forEach((item, i) => {
          const card = buildCard(item, L);
          card.style.animationDelay = (i * 40) + 'ms';
          innerGrid.appendChild(card);
        });
        grid.appendChild(innerGrid);
      }
    } else {
      // Flat grid — single category selected
      const innerGrid = document.createElement('div');
      innerGrid.className = 'items-inner-grid';
      filtered.forEach((item, i) => {
        const card = buildCard(item, L);
        card.style.animationDelay = (i * 40) + 'ms';
        innerGrid.appendChild(card);
      });
      grid.appendChild(innerGrid);
    }
  }

  function buildCard(item, L) {
    const card = document.createElement('div');
    card.className = 'card' + (item.is_available === false ? ' unavailable' : '');

    const badgeLabel = item.badge ? (L.badges[item.badge] || item.badge) : '';
    const badgeHTML  = badgeLabel ? `<span class="badge ${BADGE_CLASS[item.badge] || ''}">${badgeLabel}</span>` : '';
    const unavailHTML = item.is_available === false ? `<div class="unavailable-tag">${L.unavailable}</div>` : '';
    const localName  = getLocalized(item, 'name', currentLang);
    const localDesc  = getLocalized(item, 'description', currentLang);

    card.innerHTML = `
      <div class="card-img-wrap">
        <img src="${item.image_url || 'https://placehold.co/400x300?text=No+Image'}" alt="${localName}" loading="lazy" />
        ${badgeHTML}${unavailHTML}
      </div>
      <div class="card-body">
        <h3>${localName}</h3>
        <p class="card-desc">${localDesc}</p>
        <div class="card-footer">
          <span class="price">${CURRENCY}${item.price}</span>
          ${CART_ENABLED && item.is_available !== false ? `<button class="add-btn">${L.addToCart}</button>` : ''}
        </div>
      </div>`;

    if (item.is_available !== false) {
      card.querySelector('.card-img-wrap').addEventListener('click', () => openModal(item));
      card.querySelector('h3').addEventListener('click', () => openModal(item));
      const addBtn = card.querySelector('.add-btn');
      if (addBtn) {
        addBtn.addEventListener('click', e => {
          e.stopPropagation();
          addToCart(item, 1);
          const btn = e.currentTarget;
          btn.textContent = '✓';
          setTimeout(() => { btn.textContent = LANG[currentLang].addToCart; }, 800);
        });
      }
    }
    return card;
  }

  // ── Modal ─────────────────────────────────────────
  function openModal(item) {
    const L = LANG[currentLang];
    modalItem = item;
    modalQty  = 1;
    if (CART_ENABLED) document.getElementById('modalQtyVal').textContent = 1;
    document.getElementById('modalImg').src           = item.image_url || 'https://placehold.co/500x260?text=No+Image';
    document.getElementById('modalImg').alt           = getLocalized(item, 'name', currentLang);
    document.getElementById('modalName').textContent  = getLocalized(item, 'name', currentLang);
    document.getElementById('modalPrice').textContent = CURRENCY + item.price;
    document.getElementById('modalDesc').textContent  = getLocalized(item, 'description', currentLang);
    if (CART_ENABLED && document.getElementById('modalAddBtnText'))
      document.getElementById('modalAddBtnText').textContent = L.addToCart;

    const badge = document.getElementById('modalBadge');
    if (item.badge) {
      badge.textContent   = L.badges[item.badge] || item.badge;
      badge.className     = `modal-badge ${BADGE_CLASS[item.badge] || ''}`;
      badge.style.display = '';
    } else { badge.style.display = 'none'; }

    document.getElementById('overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  if (CART_ENABLED) {
    document.getElementById('modalQtyMinus').addEventListener('click', () => {
      if (modalQty > 1) { modalQty--; document.getElementById('modalQtyVal').textContent = modalQty; }
    });
    document.getElementById('modalQtyPlus').addEventListener('click', () => {
      modalQty++; document.getElementById('modalQtyVal').textContent = modalQty;
    });
    document.getElementById('modalAddBtn').addEventListener('click', () => {
      if (!modalItem) return;
      addToCart(modalItem, modalQty);
      closeModal();
    });
  }

  function closeModal() {
    document.getElementById('overlay').classList.remove('open');
    document.body.style.overflow = '';
    modalItem = null; modalQty = 1;
  }
  document.getElementById('closeModal').addEventListener('click', closeModal);
  document.getElementById('overlay').addEventListener('click', e => { if (e.target === document.getElementById('overlay')) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModal(); if (CART_ENABLED) closeCart(); } });

  // ── Init ──────────────────────────────────────────
  setLang(currentLang);

  // Pre-fill table number from URL ?table=N (set by table QR codes)
  const _tableParam = new URLSearchParams(window.location.search).get('table');
  if (_tableParam && document.getElementById('orderTable')) {
    document.getElementById('orderTable').value = _tableParam;
  }

  // ── Valet ─────────────────────────────────────────
  function openValet() {
    document.getElementById('valetOverlay').classList.add('open');
    document.getElementById('valetTicket').focus();
    document.body.style.overflow = 'hidden';
  }
  async function sendValetRequest() {
    const ticket = document.getElementById('valetTicket').value.trim();
    const name   = document.getElementById('valetName').value.trim();
    if (!ticket) { document.getElementById('valetTicket').focus(); return; }
    const btn = document.getElementById('valetSendBtn');
    btn.disabled = true;
    try {
      await fetch('/api/valet-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tenant_id: TENANT_ID, ticket_no: ticket, customer_name: name || null })
      });
    } catch(e) {}
    // Show success state
    document.getElementById('valetForm').style.display    = 'none';
    document.getElementById('valetSuccess').style.display = 'block';
    // Auto-close after 3 seconds
    setTimeout(() => {
      closeValet();
    }, 3000);
  }

  function closeValet() {
    document.getElementById('valetOverlay').classList.remove('open');
    document.body.style.overflow = '';
    // Reset to form state for next use
    setTimeout(() => {
      document.getElementById('valetForm').style.display    = 'block';
      document.getElementById('valetSuccess').style.display = 'none';
      document.getElementById('valetSendBtn').disabled      = false;
      document.getElementById('valetTicket').value = '';
      document.getElementById('valetName').value   = '';
    }, 300);
  }
  if (VALET_ENABLED) {
    document.getElementById('valetOverlay').addEventListener('click', e => {
      if (e.target === document.getElementById('valetOverlay')) closeValet();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeValet(); });
    document.getElementById('valetTicket').addEventListener('keydown', e => { if (e.key === 'Enter') sendValetRequest(); });
  }

  // ── Splash ────────────────────────────────────────
  function showSplash() {
    const splash = document.getElementById('splash');
    splash.style.display = 'flex';
    void splash.offsetWidth; // force reflow before removing 'out'
    splash.classList.remove('out');
  }

  function selectLang(lang) {
    setLang(lang);
    const splash = document.getElementById('splash');
    splash.classList.add('out');
    setTimeout(() => { splash.style.display = 'none'; }, 460);
  }

  function splashValet() {
    // Dismiss splash first, then open valet modal
    const splash = document.getElementById('splash');
    splash.classList.add('out');
    setTimeout(() => {
      splash.style.display = 'none';
      if (VALET_ENABLED) openValet();
    }, 460);
  }

  function splashFeedback() {
    const splash = document.getElementById('splash');
    splash.classList.add('out');
    setTimeout(() => {
      splash.style.display = 'none';
      openFeedback();
    }, 460);
  }

  // ── Feedback ──────────────────────────────────────
  const fbRatings = [0, 0, 0, 0, 0];

  function openFeedback() {
    fbRatings.fill(0);
    document.querySelectorAll('.fb-q-star').forEach(s => s.classList.remove('sel'));
    document.getElementById('fbComment').value = '';
    document.getElementById('fbName').value = '';
    document.getElementById('fbMobile').value = '';
    document.getElementById('fbTable').value = '';
    document.getElementById('fbForm').style.display = '';
    document.getElementById('fbSuccess').style.display = 'none';
    document.getElementById('fbSubmitBtn').disabled = false;
    document.getElementById('fbOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeFeedback() {
    document.getElementById('fbOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  function fbOverlayClick(e) {
    if (e.target === document.getElementById('fbOverlay')) closeFeedback();
  }

  function selectStar(q, val) {
    fbRatings[q - 1] = val;
    document.querySelectorAll(`.fb-q-star[data-q="${q}"]`).forEach(s => {
      s.classList.toggle('sel', parseInt(s.dataset.v) <= val);
    });
  }

  async function submitFeedback() {
    if (fbRatings.every(r => r === 0)) {
      const el = document.getElementById('fbQ1');
      el.style.animation = 'none';
      void el.offsetWidth;
      el.style.animation = 'shake .3s ease';
      return;
    }
    const btn = document.getElementById('fbSubmitBtn');
    btn.disabled = true;
    const avg = Math.round(fbRatings.filter(r => r > 0).reduce((a, b) => a + b, 0) / fbRatings.filter(r => r > 0).length);
    try {
      await fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tenant_id: TENANT_ID,
          rating: avg,
          q1: fbRatings[0] || null,
          q2: fbRatings[1] || null,
          q3: fbRatings[2] || null,
          q4: fbRatings[3] || null,
          q5: fbRatings[4] || null,
          customer_name: document.getElementById('fbName').value.trim() || null,
          mobile: document.getElementById('fbMobile').value.trim() || null,
          table_no: document.getElementById('fbTable').value.trim() || null,
          comment: document.getElementById('fbComment').value.trim() || null
        })
      });
    } catch(e) {}
    document.getElementById('fbForm').style.display = 'none';
    document.getElementById('fbSuccess').style.display = 'block';
    setTimeout(() => closeFeedback(), 2800);
  }
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Super Admin — All Restaurants</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f0f1a; color: #e0e0e0; min-height: 100vh; }

    .topbar { background: #1a1a2e; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,.07); position: sticky; top: 0; z-index: 100; }
    .topbar-brand { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; font-size: 1rem; }
    .topbar-brand span { font-size: 1.4rem; }
    .topbar-actions { display: flex; align-items: center; gap: 12px; }
    .btn { padding: 8px 18px; border: none; border-radius: 8px; cursor: pointer; font-size: .85rem; font-weight: 600; font-family: inherit; }
    .btn-primary { background: #7c5cbf; color: #fff; }
    .btn-primary:hover { opacity: .88; }
    .btn-ghost { background: rgba(255,255,255,.08); color: #ccc; }
    .btn-ghost:hover { background: rgba(255,255,255,.14); color: #fff; }
    .btn-sm { padding: 6px 12px; font-size: .78rem; }
    .btn-danger { background: rgba(255,71,87,.15); color: #ff6b7a; border: 1px solid rgba(255,71,87,.3); }
    .btn-danger:hover { background: rgba(255,71,87,.25); }
    .btn-success { background: rgba(0,184,148,.12); color: #00b894; border: 1px solid rgba(0,184,148,.3); }
    .btn-success:hover { background: rgba(0,184,148,.22); }

    .main { padding: 32px; max-width: 1200px; margin: 0 auto; }

    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: #1a1a2e; border-radius: 14px; padding: 20px 24px; border: 1px solid rgba(255,255,255,.06); }
    .stat-label { font-size: .75rem; color: #666; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
    .stat-value { font-size: 2rem; font-weight: 700; color: #fff; }
    .stat-value.accent { color: #7c5cbf; }

    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }

    .table-wrap { background: #1a1a2e; border-radius: 14px; border: 1px solid rgba(255,255,255,.06); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: .72rem; color: #555; font-weight: 600; padding: 14px 18px; text-transform: uppercase; letter-spacing: .4px; border-bottom: 1px solid rgba(255,255,255,.06); }
    td { padding: 14px 18px; border-top: 1px solid rgba(255,255,255,.04); font-size: .85rem; vertical-align: middle; }
    tr:hover td { background: rgba(255,255,255,.02); }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: .72rem; font-weight: 700; }
    .badge-active { background: rgba(0,184,148,.15); color: #00b894; }
    .badge-inactive { background: rgba(255,71,87,.15); color: #ff6b7a; }

    .actions { display: flex; gap: 6px; flex-wrap: wrap; }

    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 200; align-items: center; justify-content: center; }
    .overlay.open { display: flex; }
    .modal { background: #1a1a2e; border-radius: 16px; padding: 28px; width: 480px; max-width: calc(100% - 32px); border: 1px solid rgba(255,255,255,.1); }
    .modal.wide { width: 620px; max-height: 90vh; overflow-y: auto; }
    .style-options { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
    .style-opt { padding: 8px 14px; border: 2px solid #333; border-radius: 8px; cursor: pointer; font-size: .8rem; font-weight: 600; color: #888; transition: all .15s; background: #0f0f1a; user-select: none; }
    .style-opt:hover { border-color: #555; color: #ccc; }
    .style-opt.active { border-color: #7c5cbf; color: #fff; background: rgba(124,92,191,.15); }
    .style-swatch { width: 28px; height: 28px; border-radius: 6px; border: 2px solid #333; cursor: pointer; flex-shrink: 0; }
    .color-row { display: flex; align-items: center; gap: 10px; }
    .color-hex { font-family: monospace; font-size: .85rem; color: #888; }
    .modal h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 20px; }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
    .form-group { margin-bottom: 14px; }
    label { display: block; font-size: .78rem; font-weight: 600; color: #888; margin-bottom: 6px; }
    input, textarea { width: 100%; padding: 10px 12px; background: #0f0f1a; border: 1.5px solid #333; border-radius: 8px; color: #fff; font-size: .88rem; outline: none; font-family: inherit; transition: border-color .2s; }
    input:focus, textarea:focus { border-color: #7c5cbf; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    #toast { position: fixed; bottom: 28px; right: 28px; padding: 12px 20px; border-radius: 10px; font-size: .88rem; font-weight: 500; box-shadow: 0 8px 24px rgba(0,0,0,.4); transform: translateY(80px); opacity: 0; transition: transform .3s, opacity .3s; z-index: 999; background: #1a1a2e; color: #fff; border: 1px solid rgba(255,255,255,.1); }
    #toast.show { transform: translateY(0); opacity: 1; }
    #toast.success { border-color: rgba(0,184,148,.5); color: #00b894; }
    #toast.error { border-color: rgba(255,71,87,.5); color: #ff6b7a; }

    .feat-toggle { width: 44px; height: 24px; border-radius: 12px; background: #333; position: relative; transition: background .2s; cursor: pointer; flex-shrink: 0; }
    .feat-toggle::after { content:''; position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#666; transition: transform .2s, background .2s; }
    .feat-toggle.on { background: #7c5cbf; }
    .feat-toggle.on::after { transform: translateX(20px); background: #fff; }
    .feat-row.on { border-color: #7c5cbf; }

    @media (max-width: 768px) {
      .stats { grid-template-columns: 1fr 1fr; }
      .main { padding: 16px; }
      .topbar { padding: 0 16px; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">
    <span>⚡</span> Super Admin
  </div>
  <div class="topbar-actions">
    <button class="btn btn-primary" onclick="openCreate()">+ New Restaurant</button>
    <form method="POST" action="/superadmin/logout" style="display:inline">
      <button class="btn btn-ghost" type="submit">Logout</button>
    </form>
  </div>
</div>

<div class="main">

  <!-- Stats -->
  <div class="stats">
    <div class="stat-card">
      <div class="stat-label">Total Restaurants</div>
      <div class="stat-value accent"><%= stats.total %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Active</div>
      <div class="stat-value"><%= stats.active %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Menu Views</div>
      <div class="stat-value"><%= stats.totalViews.toLocaleString() %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Orders</div>
      <div class="stat-value"><%= stats.totalOrders %></div>
    </div>
  </div>

  <!-- Restaurants table -->
  <div class="section-header">
    <h2>All Restaurants (<%= tenants.length %>)</h2>
  </div>

  <div class="table-wrap">
    <% if (tenants.length === 0) { %>
      <p style="text-align:center;padding:48px;color:#555">No restaurants yet. Create the first one.</p>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Restaurant</th>
          <th>Subdomain</th>
          <th>Admin Email</th>
          <th>Views</th>
          <th>Items</th>
          <th>Orders</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% tenants.forEach(t => { %>
        <tr>
          <td>
            <strong style="color:#fff"><%= t.name %></strong>
          </td>
          <td><span style="color:#7c5cbf;font-family:monospace"><%= t.subdomain %></span></td>
          <td style="color:#888"><%= t.admin_email || '—' %></td>
          <td><%= (t.view_count || 0).toLocaleString() %></td>
          <td><%= t.item_count || 0 %></td>
          <td><%= t.order_count || 0 %></td>
          <td>
            <span class="badge <%= t.active ? 'badge-active' : 'badge-inactive' %>">
              <%= t.active ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td style="color:#666"><%= new Date(t.created_at).toLocaleDateString() %></td>
          <td>
            <div class="actions">
              <a href="/superadmin/tenants/<%= t.id %>/login" class="btn btn-ghost btn-sm">Login</a>
              <a href="http://<%= t.subdomain %>.m-menus.com" target="_blank" class="btn btn-ghost btn-sm">View</a>
              <button class="btn btn-ghost btn-sm" onclick="openEdit(<%= JSON.stringify(t) %>)" style="color:#00b894">Edit</button>
              <button class="btn btn-ghost btn-sm" onclick="openStyle(<%= JSON.stringify(t) %>)" style="color:#f39c12">Style</button>
              <button class="btn btn-ghost btn-sm" onclick="openFeatures(<%= JSON.stringify(t) %>)" style="color:#7c5cbf">
                Features
                <span style="margin-left:5px;font-size:.7rem;opacity:.7" title="Feedback / Orders / Import / CSS / Lang / Valet">
                  <% ['feat_feedback','feat_orders','feat_import','feat_custom_css','feat_multilang','feat_valet','feat_splash_custom','feat_cart','feat_pos'].forEach(f => { %><span style="color:<%= t[f] === false ? '#ff6b7a' : '#00b894' %>">●</span><% }) %>
                </span>
              </button>
              <form method="POST" action="/superadmin/tenants/<%= t.id %>/toggle" style="display:inline">
                <button class="btn btn-sm <%= t.active ? 'btn-danger' : 'btn-success' %>" type="submit">
                  <%= t.active ? 'Disable' : 'Enable' %>
                </button>
              </form>
              <form method="POST" action="/superadmin/tenants/<%= t.id %>/delete" style="display:inline" onsubmit="return confirm('Delete <%= t.name %>? This cannot be undone.')">
                <button class="btn btn-danger btn-sm" type="submit">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<!-- Features Modal -->
<div class="overlay" id="featuresOverlay">
  <div class="modal">
    <h3>⚙️ Features — <span id="featRestName"></span></h3>
    <p style="color:#666;font-size:.82rem;margin-bottom:20px">Control which features this restaurant can access. Disabled features are hidden from their admin panel.</p>
    <form method="POST" id="featuresForm">
      <% const FEATS = [
        { key:'feat_feedback',   icon:'💬', label:'Customer Feedback',    desc:'Feedback button on menu + admin feedback page' },
        { key:'feat_orders',     icon:'📋', label:'Orders Tracking',      desc:'Log customer orders, view order history' },
        { key:'feat_import',     icon:'📥', label:'Excel Import',         desc:'Bulk import menu items via Excel file' },
        { key:'feat_custom_css', icon:'🎨', label:'Custom CSS',           desc:'Custom styling for their menu page' },
        { key:'feat_multilang',  icon:'🌐', label:'Multi-language (AR/KU)', desc:'Arabic and Kurdish language support' },
        { key:'feat_valet',      icon:'🚗', label:'Valet Parking',        desc:'Valet request system for customers' },
        { key:'feat_splash_custom', icon:'🖼️', label:'Splash Screen Style', desc:'Customize splash background, colors, and overlay' },
        { key:'feat_cart',         icon:'🛒', label:'Shopping Cart',        desc:'Cart & WhatsApp ordering on the menu' },
        { key:'feat_pos',          icon:'🖥️', label:'Point of Sale (POS)',   desc:'Full POS system — tables, orders, payments, kitchen display' },
      ]; %>
      <div style="display:flex;flex-direction:column;gap:10px">
        <% FEATS.forEach(f => { %>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:14px;border:1.5px solid #333;border-radius:10px;cursor:pointer;transition:border-color .2s" class="feat-row" data-key="<%= f.key %>" onclick="toggleFeat('<%= f.key %>')">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-size:1.3rem"><%= f.icon %></span>
            <div>
              <div style="color:#fff;font-weight:600;font-size:.88rem"><%= f.label %></div>
              <div style="color:#666;font-size:.75rem;margin-top:2px"><%= f.desc %></div>
            </div>
          </div>
          <div class="toggle-wrap" style="display:flex;align-items:center;gap:8px">
            <span id="fl_<%= f.key %>" style="font-size:.72rem;font-weight:700;width:26px;text-align:right;color:#666">OFF</span>
            <input type="hidden" name="<%= f.key %>" id="fv_<%= f.key %>" value="0" />
            <div class="feat-toggle" id="ft_<%= f.key %>"></div>
          </div>
        </div>
        <% }) %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeFeatures()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Features</button>
      </div>
    </form>
  </div>
</div>

<!-- Create Restaurant Modal -->
<div class="overlay" id="createOverlay">
  <div class="modal">
    <h3>➕ New Restaurant</h3>
    <form method="POST" action="/superadmin/tenants">
      <div class="form-grid">
        <div class="form-group">
          <label>Restaurant Name *</label>
          <input type="text" name="name" required placeholder="Burger House" />
        </div>
        <div class="form-group">
          <label>Subdomain * (no spaces)</label>
          <input type="text" name="subdomain" required placeholder="burgerhouse" pattern="[a-zA-Z0-9\-]+" />
        </div>
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="Best burgers in town" />
      </div>
      <div class="form-grid">
        <div class="form-group">
          <label>Admin Email *</label>
          <input type="email" name="admin_email" required placeholder="admin@burgerhouse.com" />
        </div>
        <div class="form-group">
          <label>Admin Password *</label>
          <input type="password" name="admin_password" required placeholder="Min 6 characters" minlength="6" />
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeCreate()">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Restaurant</button>
      </div>
    </form>
  </div>
</div>

<!-- Style Modal -->
<div class="overlay" id="styleOverlay">
  <div class="modal wide">
    <h3>🎨 Style — <span id="styleRestName"></span></h3>
    <form method="POST" id="styleForm">

      <!-- Theme Color -->
      <div class="form-group">
        <label>Theme Color</label>
        <div class="color-row">
          <input type="color" id="styleColorPicker" value="#7c5cbf" style="width:44px;height:36px;padding:2px;background:#0f0f1a;border:2px solid #333;border-radius:8px;cursor:pointer" oninput="document.getElementById('styleColorHex').value=this.value;document.getElementById('styleColorInput').value=this.value" />
          <input type="text" id="styleColorHex" maxlength="7" placeholder="#7c5cbf" style="width:110px" oninput="syncColorHex(this.value)" />
          <input type="hidden" name="theme_color" id="styleColorInput" />
          <span class="color-hex">Used for buttons, highlights, and accents</span>
        </div>
      </div>

      <!-- Menu Style -->
      <div class="form-group">
        <label>Menu Style</label>
        <div class="style-options" id="styleStyleOpts">
          <div class="style-opt" data-val="dark" onclick="pickOpt('styleStyleOpts','stylMenuStyle',this)">🌑 Dark</div>
          <div class="style-opt" data-val="light" onclick="pickOpt('styleStyleOpts','stylMenuStyle',this)">☀️ Light</div>
          <div class="style-opt" data-val="warm" onclick="pickOpt('styleStyleOpts','stylMenuStyle',this)">🍂 Warm</div>
        </div>
        <input type="hidden" name="menu_style" id="stylMenuStyle" value="dark" />
      </div>

      <!-- Menu Layout -->
      <div class="form-group">
        <label>Menu Layout</label>
        <div class="style-options" id="styleLayoutOpts">
          <div class="style-opt" data-val="grid" onclick="pickOpt('styleLayoutOpts','stylMenuLayout',this)">▦ Grid</div>
          <div class="style-opt" data-val="list" onclick="pickOpt('styleLayoutOpts','stylMenuLayout',this)">☰ List</div>
          <div class="style-opt" data-val="large" onclick="pickOpt('styleLayoutOpts','stylMenuLayout',this)">▬ Large</div>
        </div>
        <input type="hidden" name="menu_layout" id="stylMenuLayout" value="grid" />
      </div>

      <!-- Menu Font -->
      <div class="form-group">
        <label>Menu Font</label>
        <div class="style-options" id="styleFontOpts">
          <div class="style-opt" data-val="default" onclick="pickOpt('styleFontOpts','stylMenuFont',this)">Default</div>
          <div class="style-opt" data-val="elegant" onclick="pickOpt('styleFontOpts','stylMenuFont',this)">Elegant</div>
          <div class="style-opt" data-val="rounded" onclick="pickOpt('styleFontOpts','stylMenuFont',this)">Rounded</div>
        </div>
        <input type="hidden" name="menu_font" id="stylMenuFont" value="default" />
      </div>

      <!-- Custom CSS -->
      <div class="form-group">
        <label>Custom CSS <span style="color:#555;font-weight:400;font-size:.73rem">— injected into the customer menu page</span></label>
        <textarea name="custom_css" id="styleCSS" rows="7" placeholder="/* e.g. change card corners */&#10;.card { border-radius: 0; }&#10;&#10;/* e.g. custom background */&#10;body { background: #111; }" style="font-family:monospace;font-size:.82rem;resize:vertical"></textarea>

        <!-- CSS Reference -->
        <div style="margin-top:10px">
          <button type="button" onclick="toggleRef()" style="background:none;border:none;color:#7c5cbf;font-size:.78rem;font-weight:600;cursor:pointer;padding:0;font-family:inherit">▶ CSS Selector Reference</button>
          <div id="cssRef" style="display:none;margin-top:10px;border:1px solid #2a2a3e;border-radius:10px;overflow:hidden;font-size:.78rem">
            <div style="background:#0f0f1a;padding:8px 14px;color:#555;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.4px">Click a selector to insert it into the CSS editor</div>
            <% const CSS_REF = [
              ['body',              'Overall page background and text color'],
              ['.splash',           'Splash / welcome screen (full page)'],
              ['.splash-top',       'Top area of splash (logo zone)'],
              ['.splash-center',    'Center area of splash (language buttons)'],
              ['.splash-bottom',    'Bottom area of splash'],
              ['.nav-bar',          'Sticky top navigation bar'],
              ['.cat-nav',          'Horizontal category scroll bar'],
              ['.cat-btn',          'Individual category button'],
              ['.cat-btn.active',   'Currently selected category button'],
              ['.card',             'Menu item card'],
              ['.card-img',         'Item card image'],
              ['.card-body',        'Item card text area'],
              ['.card-name',        'Item name on card'],
              ['.card-desc',        'Item short description on card'],
              ['.card-price',       'Item price on card'],
              ['.badge',            'Item badge (New, Popular, Chef, etc.)'],
              ['.modal-box',        'Item detail popup (full sheet)'],
              ['.modal-title',      'Item name inside the detail popup'],
              ['.modal-price',      'Item price inside the detail popup'],
              ['.modal-desc',       'Item description inside the detail popup'],
              ['.btn-addcart',      '"Add to Cart" button'],
              ['.cart-fab',         'Floating cart button (bottom right)'],
              ['.cart-drawer',      'Cart side drawer'],
              ['.cart-item',        'A single row inside the cart'],
              ['.section-title',    'Category section heading on the menu'],
              ['.search-bar',       'Search input field'],
              ['.footer-powered',   '"Powered by m-menus.com" footer'],
            ]; %>
            <% CSS_REF.forEach(([sel, desc], i) => { %>
            <div onclick="insertSelector('<%= sel %>')" style="display:flex;align-items:center;justify-content:space-between;padding:9px 14px;cursor:pointer;border-top:<%= i===0 ? 'none' : '1px solid #1e1e2e' %>;transition:background .1s" onmouseover="this.style.background='rgba(124,92,191,.08)'" onmouseout="this.style.background='transparent'">
              <code style="color:#00b894;font-size:.8rem;font-family:monospace"><%= sel %></code>
              <span style="color:#555;font-size:.73rem;text-align:right;max-width:55%"><%= desc %></span>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeStyle()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Style</button>
      </div>
    </form>
  </div>
</div>

<div id="toast"></div>

<!-- Edit Restaurant Modal -->
<div class="overlay" id="editOverlay">
  <div class="modal">
    <h3>✏️ Edit Restaurant</h3>
    <form method="POST" id="editForm">
      <div class="form-group">
        <label>Restaurant Name</label>
        <input type="text" name="name" id="editName" required />
      </div>
      <div class="form-group">
        <label>Subdomain (no spaces)</label>
        <input type="text" name="subdomain" id="editSubdomain" required pattern="[a-zA-Z0-9\-]+" />
        <div style="color:#666;font-size:.75rem;margin-top:4px">URL: <span id="editPreview" style="color:#7c5cbf"></span>.m-menus.com</div>
      </div>
      <div class="form-group">
        <label>Admin Email</label>
        <input type="email" name="admin_email" id="editEmail" />
      </div>
      <div class="form-group">
        <label>New Password <span style="color:#666;font-weight:400;font-size:.75rem">(leave blank to keep current)</span></label>
        <input type="password" name="admin_password" id="editPassword" placeholder="Enter new password" minlength="6" />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeEdit()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openCreate() { document.getElementById('createOverlay').classList.add('open'); }
  function closeCreate() { document.getElementById('createOverlay').classList.remove('open'); }
  document.getElementById('createOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeCreate(); });

  function openEdit(t) {
    document.getElementById('editForm').action = '/superadmin/tenants/' + t.id + '/edit';
    document.getElementById('editName').value = t.name;
    document.getElementById('editSubdomain').value = t.subdomain;
    document.getElementById('editEmail').value    = t.admin_email || '';
    document.getElementById('editPassword').value = '';
    document.getElementById('editPreview').textContent = t.subdomain;
    document.getElementById('editOverlay').classList.add('open');
  }
  function closeEdit() { document.getElementById('editOverlay').classList.remove('open'); }
  document.getElementById('editOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeEdit(); });
  document.getElementById('editSubdomain').addEventListener('input', function() {
    document.getElementById('editPreview').textContent = this.value;
  });

  const FEAT_KEYS = ['feat_feedback','feat_orders','feat_import','feat_custom_css','feat_multilang','feat_valet','feat_splash_custom','feat_cart','feat_pos'];

  function toggleFeat(key) {
    const inp = document.getElementById('fv_' + key);
    inp.value = inp.value === '1' ? '0' : '1';
    updateFeatUI(key);
  }
  function updateFeatUI(key) {
    const on = document.getElementById('fv_' + key).value === '1';
    document.getElementById('ft_' + key).classList.toggle('on', on);
    document.querySelector('[data-key="' + key + '"]').classList.toggle('on', on);
    const lbl = document.getElementById('fl_' + key);
    if (lbl) { lbl.textContent = on ? 'ON' : 'OFF'; lbl.style.color = on ? '#7c5cbf' : '#888'; }
  }
  function openFeatures(tenant) {
    document.getElementById('featRestName').textContent = tenant.name;
    document.getElementById('featuresForm').action = '/superadmin/tenants/' + tenant.id + '/features';
    FEAT_KEYS.forEach(key => {
      document.getElementById('fv_' + key).value = (tenant[key] !== false) ? '1' : '0';
      updateFeatUI(key);
    });
    document.getElementById('featuresOverlay').classList.add('open');
  }
  function closeFeatures() { document.getElementById('featuresOverlay').classList.remove('open'); }
  document.getElementById('featuresOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeFeatures(); });

  function toggleRef() {
    const el = document.getElementById('cssRef');
    const btn = el.previousElementSibling;
    const open = el.style.display === 'none';
    el.style.display = open ? 'block' : 'none';
    btn.textContent = (open ? '▼' : '▶') + ' CSS Selector Reference';
  }
  function insertSelector(sel) {
    const ta = document.getElementById('styleCSS');
    const snippet = sel + ' {\n  \n}\n';
    const pos = ta.selectionEnd;
    const before = ta.value.slice(0, pos);
    const after = ta.value.slice(pos);
    const sep = before.length > 0 && !before.endsWith('\n') ? '\n\n' : before.endsWith('\n\n') ? '' : '\n';
    ta.value = before + sep + snippet + after;
    const cursorPos = before.length + sep.length + sel.length + 3;
    ta.focus();
    ta.setSelectionRange(cursorPos, cursorPos);
  }

  function pickOpt(groupId, hiddenId, el) {
    document.querySelectorAll('#' + groupId + ' .style-opt').forEach(o => o.classList.remove('active'));
    el.classList.add('active');
    document.getElementById(hiddenId).value = el.dataset.val;
  }
  function setOpt(groupId, hiddenId, val) {
    document.querySelectorAll('#' + groupId + ' .style-opt').forEach(o => {
      o.classList.toggle('active', o.dataset.val === val);
    });
    document.getElementById(hiddenId).value = val;
  }
  function syncColorHex(v) {
    if (/^#[0-9a-fA-F]{6}$/.test(v)) {
      document.getElementById('styleColorPicker').value = v;
      document.getElementById('styleColorInput').value = v;
    }
  }
  function openStyle(t) {
    document.getElementById('styleForm').action = '/superadmin/tenants/' + t.id + '/style';
    document.getElementById('styleRestName').textContent = t.name;
    const color = t.theme_color || '#7c5cbf';
    document.getElementById('styleColorPicker').value = color;
    document.getElementById('styleColorHex').value = color;
    document.getElementById('styleColorInput').value = color;
    setOpt('styleStyleOpts', 'stylMenuStyle', t.menu_style || 'dark');
    setOpt('styleLayoutOpts', 'stylMenuLayout', t.menu_layout || 'grid');
    setOpt('styleFontOpts', 'stylMenuFont', t.menu_font || 'default');
    document.getElementById('styleCSS').value = t.custom_css || '';
    document.getElementById('styleOverlay').classList.add('open');
  }
  function closeStyle() { document.getElementById('styleOverlay').classList.remove('open'); }
  document.getElementById('styleOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeStyle(); });

  const params = new URLSearchParams(location.search);
  if (params.get('success')) {
    const t = document.getElementById('toast');
    t.textContent = '✓ ' + decodeURIComponent(params.get('success'));
    t.className = 'show success';
    setTimeout(() => t.className = '', 3500);
  }
  if (params.get('error')) {
    const t = document.getElementById('toast');
    t.textContent = '✗ ' + decodeURIComponent(params.get('error'));
    t.className = 'show error';
    setTimeout(() => t.className = '', 4000);
  }
</script>
</body>
</html>

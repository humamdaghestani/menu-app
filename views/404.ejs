<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Menu Not Found</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      background: #1a1a2e; color: #fff;
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }
    .card {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 52px 40px; text-align: center;
      max-width: 420px; width: 100%;
      backdrop-filter: blur(12px);
    }
    .emoji { font-size: 4rem; margin-bottom: 20px; display: block; }
    h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 10px; color: #fff; }
    p {
      color: rgba(255,255,255,0.55); font-size: .95rem; line-height: 1.6;
      margin-bottom: 32px;
    }
    .slug {
      display: inline-block; background: rgba(255,255,255,0.1);
      border-radius: 8px; padding: 4px 12px; font-family: monospace;
      font-size: .9rem; color: rgba(255,255,255,0.7); margin-bottom: 32px;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: #e94560; color: #fff; border: none; border-radius: 12px;
      padding: 13px 28px; font-size: .95rem; font-weight: 700;
      cursor: pointer; text-decoration: none; font-family: inherit;
      transition: opacity .2s;
    }
    .btn:hover { opacity: .88; }
    .footer { margin-top: 40px; color: rgba(255,255,255,0.25); font-size: .78rem; }
  </style>
</head>
<body>
  <div class="card">
    <span class="emoji">🍽️</span>
    <h1>Menu not found</h1>
    <% if (slug) { %>
      <p>We couldn't find a restaurant with this link.</p>
      <div class="slug"><%= slug %></div>
    <% } else { %>
      <p>No restaurant was specified. Check the link you received and try again.</p>
    <% } %>
    <a href="/" class="btn">← Go to Home</a>
    <div class="footer">Powered by MenuApp</div>
  </div>
</body>
</html>
